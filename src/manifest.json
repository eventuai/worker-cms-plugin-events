{
  "id": "events",
  "name": "Events Suite",
  "version": "0.1.0",
  "hooks": ["create", "publish", "unpublish", "delete"],
  "nav": [
    { "label": "Events", "href": "events", "roles": ["admin", "editor", "moderator", "event-helper"] }
  ],
  "permissions": [
    { "value": "events:view", "label": "Events: view events, guest lists and guests" },
    { "value": "events:write", "label": "Events: edit and delete events, guest lists, guests and EDM templates" },
    { "value": "events:checkin", "label": "Events: check in guests" }
  ],
  "credits": [
    { "key": "create_event", "label": "Create an event", "description": "Charged when a new event page is created.", "charge": "page_create", "page_type": "event", "default": 100 },
    { "key": "create_guest_list", "label": "Create a guest list", "description": "Charged when a new guest list is created.", "charge": "page_create", "page_type": "mail_list", "default": 25 },
    { "key": "import_guest", "label": "Import or add a guest", "description": "Charged per guest created, including CSV imports, contact-list adds and ad hoc guests. Free until priced.", "charge": "page_create", "page_type": "guest" },
    { "key": "create_edm", "label": "Create an EDM template", "description": "Charged when a new EDM page is created, including duplicated or sample EDMs. Free until priced.", "charge": "page_create", "page_type": "edm" },
    { "key": "create_label", "label": "Create a label template", "description": "Charged when a new event label template is created. Free until priced.", "charge": "page_create", "page_type": "label" },
    { "key": "send_edm", "label": "Send EDM email", "description": "Charged per recipient when sending an EDM to guests or guest lists. Free until priced.", "charge": "metered", "unit": "recipient" },
    { "key": "send_test_edm", "label": "Send test EDM email", "description": "Charged per test email sent from the EDM editor. Free until priced.", "charge": "metered", "unit": "email" },
    { "key": "duplicate_event", "label": "Duplicate an event", "description": "Charged per duplicate-event operation. Created events, lists and guests may also be charged by their page-create prices. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "archive_event", "label": "Archive or restore an event", "description": "Charged per event archive or restore operation. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "delete_event", "label": "Delete an event", "description": "Charged per event cascade-delete operation. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "delete_guest_list", "label": "Delete a guest list", "description": "Charged per guest-list delete operation. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "delete_guest", "label": "Delete a guest", "description": "Charged per guest delete operation. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "export_guests", "label": "Export guests", "description": "Charged per guest export from an event or guest list. Free until priced.", "charge": "metered", "unit": "export" },
    { "key": "assign_edm_to_guest_list", "label": "Assign EDM to guest list", "description": "Charged when an EDM is attached to a guest list. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "update_guest_status", "label": "Update guest RSVP status", "description": "Charged per manual guest status change. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "assign_guest_color", "label": "Assign guest color tag", "description": "Charged per guest color-tag change. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "check_in_guest", "label": "Check in a guest", "description": "Charged per manual guest check-in. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "pair_guest_qrcode", "label": "Pair guest QR code", "description": "Charged per badge QR pairing operation. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "move_guest", "label": "Move guest to another list", "description": "Charged per guest move between lists. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "sync_guest_from_contact", "label": "Sync guest from contact", "description": "Charged per linked guest refreshed from its contact record. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "remove_contact_guests", "label": "Remove contact guests from list", "description": "Charged per guest removed from a guest list through the contacts browser. Free until priced.", "charge": "metered", "unit": "guest" },
    { "key": "reorder_event_guest_lists", "label": "Reorder event guest lists", "description": "Charged per guest-list reorder operation on an event. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "reorder_event_sessions", "label": "Reorder event sessions", "description": "Charged per event-session reorder operation. Free until priced.", "charge": "metered", "unit": "operation" },
    { "key": "reorder_guest_list_guests", "label": "Reorder guests", "description": "Charged per guest reorder operation inside a guest list. Free until priced.", "charge": "metered", "unit": "operation" }
  ],
  "limits": [
    { "key": "max_events", "label": "Maximum events", "description": "Total number of events.", "page_type": "event", "scope": "total" },
    { "key": "max_guest_lists", "label": "Maximum guest lists", "description": "Total guest lists across all events.", "page_type": "mail_list", "scope": "total" },
    { "key": "max_lists_per_event", "label": "Guest lists per event", "description": "Guest lists attached to a single event.", "page_type": "mail_list", "scope": "per_pointer", "pointer_key": "event" },
    { "key": "max_guests", "label": "Maximum guests", "description": "Total guests across all guest lists.", "page_type": "guest", "scope": "total" },
    { "key": "max_guests_per_list", "label": "Guests per guest list", "description": "Guests in a single guest list, including imports.", "page_type": "guest", "scope": "per_pointer", "pointer_key": "mail_list" }
  ],
  "assets": [
    { "path": "/assets/event-new.js", "label": "New event auto slug" },
    { "path": "/assets/picture-upload.js", "label": "Picture field upload" }
  ],
  "editViews": ["edm", "guest"],
  "newViews": ["event"],
  "contentTypes": {
    "readTypes": ["contact"],
    "blueprint": {
      "event": [
        "@type", "@label", "@rfid:switch",
        "@show_guest_info:switch", "@waiting_message", "@kiosk_title", "@checkin_require_login:switch", "@checkin_lite_passcode",
        "@virtual_event_link", "@featured_image:picture", "logo:picture", "name:text/title",
        "location:location", "description:textarea",
        {
          "session": [
            "@checkin:switch", "@type", "@start:date/datetime", "@duration", "@capacity", "name:text/title",
            "location", "description:textarea",
            { "inputs": ["@type", "@name", "@values"] }
          ]
        }
      ],
      "guest": [
        "*mail_list",
        "*contact",
        "@allow_refill:switch",
        "@picture:picture", 
        "@email:email", 
        "@primary_guest", 
        "@max_main_checkin", 
        "@nationality",
        "@cc", 
        "@organization", 
        "@plus_guests", 
        "@phone", 
        "@parent",
        "@rsvp_code", 
        "@status", 
        "@checkin_remark", 
        "@qrcode_remark", 
        "@not_send", 
        "@no",
        "@prefix", 
        "@prefer_language", 
        "@zh_hant_name", 
        "@zh_hans_name", 
        "@job_title", 
        "@wechat", 
        "@remarks", 
        "@total_guests", 
        "@color_tag", 
        "@qrcode", 
        "@paired_qrcode",
        "@barcode",
        "name", 
        "last_name",
        {
          "response": ["@status", "@date", "@message"],
          "checkin": ["@status", "@date", "@message"]
        }
      ],
      "label": [
        { "frame": ["@width", "@height", "@direction", "@svg"] }
      ],
      "edm": [
        "@text_color", "@font_size", "@font_family", "@bg_color", "@image_padding",
        "@button_color", "@button_text_color", "@headline_font_size", "@headline_padding",
        "@table_padding", "@paragraph_bottom_margin",
        "*event", "@sender", "@reply_to", "@bcc",
        "subject", "heading", "body:richtext/md", "landing_subject", "date_text", "time",
        "address_1", "address_2", "address_3",
        "thankyou_heading:text", "thankyou_body:richtext/md", "@thankyou_picture:picture",
        "decline_heading:text", "decline_body:richtext/md",
        "@quick_confirm:switch", "@cc_enable:switch", "rsvp_button", "rsvp_form_button", "rsvp_form_decline_button"
      ],
      "mail_list": [
        "*event", "*edm", "*mail_preview_list", "@blast_datetime", "@allow_checkin"
      ],
      "mail_preview_list": [
        "@name", { "user": ["@name", "@email"] }
      ],
      "rsvp_response": [
        "@guest_uuid", "@event_id", "@list_id", "@edm_id", "@status", "@plus_guests",
        "@message", "@language", "@submitted_at", "@applied_at", "@applied_guest_id"
      ],
      "rsvp_registration": [
        "@name", "@first_name", "@last_name", "@email", "@salutation", "@organization",
        "@job_title", "@plus_guests", "@language", "@event_id", "@edm_id",
        "@submitted_at", "@converted_guest_id", "@converted_at"
      ]
    },
    "blocks": {
      "label": ["name"],
      "logos": ["label", { "pictures": ["url"] }],
      "paragraph": ["subject", "body:richtext/md"],
      "picture": ["@picture:picture", "caption", "@width", "@align"],
      "button": ["label", "url"],
      "table": ["title:richtext/md", "@first_column_width", { "row": ["name:richtext/md", "description:richtext/md"] }],
      "spacer": ["@lines"],
      "edm-attachments": [{ "attachment": ["@file:picture", "@name"] }],
      "edm-unsubscribe": [],
      "rsvp-location": ["name", "address_1", "address_2", "address_3", "city", "state", "country"],
      "rsvp-date-time": ["date_text", "time", "timezone"],
      "rsvp-plus-one": ["@max_guests", "title"],
      "rsvp-meal-preferences": [
        "title", "body:richtext/md", "@allow_message:boolean", "message_placeholder",
        { "food": ["name", "description"] }
      ],
      "rsvp-travel-hotel": [
        "title", "body:richtext/md",
        { "flight_custom_input": ["@type", "label"] },
        { "hotel_custom_input": ["@type", "label"] }
      ],
      "rsvp-custom": [
        "title", "body:richtext/md",
        { "custom_input": ["@required:boolean", "@type", "label", "default_value"] }
      ],
      "rsvp-public-form": [
        "title", "body:richtext/md", "label_salutation", "label_first_name", "label_last_name",
        "label_email", "label_organization", "label_job_title",
        { "custom_input": ["@name", "@required:boolean", "@type", "label", "default_value"] }
      ],
      "rsvp-accept": ["label"],
      "rsvp-sessions": [],
      "rsvp-qrcode": ["title", "message", "@size"],
      "rsvp-pickup": [
        "title", "pickup_date_label", "pickup_time_label", "pickup_location_label",
        "dropoff_date_label", "dropoff_time_label", "dropoff_location_label",
        "accommodation_title", "checkin_date_label", "checkout_date_label"
      ],
      "rsvp-button": ["label"]
    },
    "blockLists": {
      "event": ["picture", "paragraph", "table", "button", "rsvp-location", "rsvp-date-time", "rsvp-plus-one", "rsvp-meal-preferences", "rsvp-travel-hotel", "rsvp-custom", "rsvp-public-form", "rsvp-accept", "rsvp-sessions", "rsvp-qrcode", "rsvp-pickup", "rsvp-button"],
      "edm": ["picture", "paragraph", "table", "button", "spacer", "edm-attachments", "edm-unsubscribe", "rsvp-location", "rsvp-date-time", "rsvp-plus-one", "rsvp-meal-preferences", "rsvp-travel-hotel", "rsvp-custom", "rsvp-public-form", "rsvp-accept", "rsvp-sessions", "rsvp-qrcode", "rsvp-pickup", "rsvp-button"],
      "mail_list": ["rsvp-location", "rsvp-date-time", "rsvp-plus-one", "rsvp-meal-preferences", "rsvp-travel-hotel", "rsvp-custom", "rsvp-public-form", "rsvp-accept", "rsvp-sessions", "rsvp-qrcode", "rsvp-pickup", "rsvp-button"]
    },
    "taxonomies": {
      "event-type": "Event Type",
      "event-categories": "Event Categories"
    },
    "taxonomyLists": {
      "event": ["event-type", "event-categories"]
    }
  }
}
