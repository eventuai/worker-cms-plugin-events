<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"></head>
<body style="margin:0;background:#f3f4f6;font-family:Arial,sans-serif;color:#111827">
  <main style="max-width:640px;margin:0 auto;padding:32px 16px">
    <article style="background:#ffffff;border-radius:12px;padding:32px;box-shadow:0 1px 3px rgba(0,0,0,.1)">
      {% if heading %}<h1 style="margin:0 0 20px;font-size:28px;line-height:1.2">{{ heading | escape }}</h1>{% endif %}
      {% if guestName %}<p style="font-size:16px">Hello {{ guestName | escape }},</p>{% endif %}
      <div style="font-size:16px;line-height:1.6">{{ body }}</div>
      {% if rsvpUrl %}<p style="margin:28px 0 0"><a href="{{ rsvpUrl | escape }}" style="display:inline-block;background:#4f46e5;color:#fff;padding:12px 18px;border-radius:6px;text-decoration:none;font-weight:700">{{ rsvp_button | escape }}</a></p>{% endif %}
    </article>
  </main>
</body></html>
