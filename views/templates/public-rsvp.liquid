<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>RSVP — {{ eventName | escape }}</title>
<style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}.card{max-width:38rem;margin:3rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002}h1{margin-top:0}label{display:block;margin:1rem 0 .4rem;font-weight:600}input,select,textarea{box-sizing:border-box;width:100%;padding:.7rem;border:1px solid #d1d5db;border-radius:.5rem;font:inherit;font-size:16px}.actions{display:flex;gap:.75rem;margin-top:1.5rem}button{border:0;border-radius:.5rem;padding:.7rem 1rem;font:inherit;font-weight:700;cursor:pointer}.yes{background:#4f46e5;color:#fff}.no{background:#f3f4f6;color:#374151}</style></head>
<body><main class="card"><p style="color:#6b7280;margin-top:0">{{ eventName | escape }}{% if listName %} · {{ listName | escape }}{% endif %}</p><h1>RSVP</h1><p>Hello {{ guestName | escape }}, please let us know whether you can attend.</p>
<form method="post" action="{{ action | escape }}"><label>Additional guests</label><input type="number" min="0" name="plus_guests" value="{{ plusGuests | escape }}"><label>Message (optional)</label><textarea name="message" rows="4" placeholder="Anything the event team should know?"></textarea><div class="actions"><button class="yes" name="status" value="confirmed" type="submit">Accept</button><button class="no" name="status" value="declined" type="submit">Decline</button></div></form></main></body></html>
