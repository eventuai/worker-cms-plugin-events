<div class="max-w-5xl mx-auto px-4 py-5">{{ content }}</div>
<script>
// Generic drag-to-reorder for any <table data-reorder="URL"> with draggable rows.
// mode "weight" posts {key:[{id,weight}]}; mode "order" posts {key:[index,...]}.
(function () {
  function closest(target, selector) {
    if (target && target.nodeType === 3) target = target.parentElement;
    return target && target.closest ? target.closest(selector) : null;
  }

  document.querySelectorAll('table[data-reorder]').forEach(function (table) {
    var tbody = table.tBodies[0];
    if (!tbody) return;
    var handleOnly = table.hasAttribute('data-reorder-handle-only');
    var dragging = null;
    tbody.addEventListener('dragstart', function (e) {
      if (handleOnly && !closest(e.target, '[data-reorder-handle]')) {
        e.preventDefault();
        return;
      }
      dragging = closest(e.target, 'tr[draggable]');
      if (!dragging) return;
      dragging.style.opacity = '0.4';
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', '');
      }
    });
    tbody.addEventListener('dragend', function () {
      if (dragging) { dragging.style.opacity = ''; dragging = null; }
    });
    tbody.addEventListener('dragover', function (e) {
      e.preventDefault();
      if (!dragging) return;
      var tr = closest(e.target, 'tr[draggable]');
      if (!tr || tr === dragging) return;
      var rect = tr.getBoundingClientRect();
      tbody.insertBefore(dragging, (e.clientY - rect.top) > rect.height / 2 ? tr.nextSibling : tr);
    });
    tbody.addEventListener('drop', function (e) {
      e.preventDefault();
      if (!dragging) return;
      var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr[draggable]'));
      var key = table.getAttribute('data-reorder-key') || 'reorder';
      var mode = table.getAttribute('data-reorder-mode') || 'weight';
      var eventId = table.getAttribute('data-reorder-event-id');
      var payload = {};
      if (eventId) payload.event_id = eventId;
      payload[key] = mode === 'order'
        ? rows.map(function (tr) { return parseInt(tr.dataset.index, 10); })
        : rows.map(function (tr, i) { return { id: parseInt(tr.dataset.id, 10), weight: i }; });
      fetch(table.getAttribute('data-reorder'), {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(function (response) {
        if (!response.ok) throw new Error('reorder failed');
        return response.json();
      }).then(function (data) {
        if (!data || data.success !== true) throw new Error((data && data.error) || 'reorder failed');
      }).catch(function () {
        window.location.reload();
      });
    });
  });
})();
</script>
