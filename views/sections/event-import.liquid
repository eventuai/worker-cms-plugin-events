<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">Import guests</h1>
    <p class="mt-1 text-sm text-gray-500">Upload one CSV for the whole event. A <code>list</code> column routes each row to that guest list (created if it doesn't exist).</p>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:40rem">
  <form method="post" action="{{ action | escape }}" enctype="multipart/form-data">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">CSV file</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="file" name="file" accept=".csv,text/csv" required></label>
    <p class="mt-1 text-sm text-gray-500">Recognised columns: <code>list</code>, <code>name</code>, <code>last_name</code>, <code>email</code>, <code>phone</code>, <code>organization</code>, <code>job_title</code>, <code>plus_guests</code>, <code>status</code>, <code>prefer_language</code>, <code>cc</code>, <code>remarks</code>.</p>
    <div class="flex flex-wrap gap-2"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Import</button></div>
  </form>
</div>
