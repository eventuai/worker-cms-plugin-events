<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.event_archive_progress.archiving_event" | t }}</h1>
  <p class="mt-1 text-sm text-gray-500">{{ eventName }}</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:40rem">
  <p class="text-sm text-gray-700 mb-4">{{ summary }}</p>
  {% if auto %}
    <p class="text-sm text-gray-600 mb-4">{{ "events.views.event_archive_progress.this_event_is_large_so_archiving_runs_in_stages_it_will_continue_automat" | t }}</p>
  {% else %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ "events.views.event_archive_progress.this_pass_could_not_make_progress_automatically_press_continue_archiving" | t }}</div>
  {% endif %}

  <form method="post" action="{{ stopAction }}" id="archive-stop-form"></form>
  <form method="post" action="{{ action }}" id="import-continue-form" data-auto="{% if auto %}1{% else %}0{% endif %}" data-long-running-form>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="{{ "events.views.event_archive_progress.continue_archiving" | t }}" aria-label="{{ "events.views.event_archive_progress.continue_archiving" | t }}" data-loading-label="{{ "events.views.event_archive_progress.continuing_archiving" | t }}">
        <span>{{ "events.views.event_archive_progress.continue_archiving" | t }}</span>
      </button>
      <button type="submit" form="archive-stop-form" data-stop-continue class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors cursor-pointer sm:w-auto">{{ "events.views.event_archive_progress.stop_for_now" | t }}</button>
    </div>
  </form>
</div>

<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
<script src="/admin/plugins/events/assets/import-continue.js" defer></script>
