<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventBase | escape }}">← {{ event.name | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">Public registrations</h1>
    <p class="mt-1 text-sm text-gray-500">Self-registrations from the public RSVP site. Convert adds the person to this event's Adhoc guest list; discard moves the review copy to trash (the stored submission itself is never deleted).</p>
  </div>
  <form method="post" action="{{ base | escape }}/pull">
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit">Pull new submissions</button>
  </form>
</div>

{% if flash != blank %}
<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash | escape }}</p>
{% endif %}

{% if pendingResponses > 0 %}
<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ pendingResponses }} RSVP response(s) are ingested but not yet applied to their guests — "Pull new submissions" applies them.</p>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg font-bold text-gray-900">Waiting for review</h2>
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ pending | size }}</span>
  </div>
  {% if pending != empty %}
  <table class="w-full text-left text-sm">
    <thead>
      <tr>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500">Name</th>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500">Email</th>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500">Organization</th>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500">+Guests</th>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500">Submitted</th>
        <th class="px-6 py-3 text-xs font-semibold text-gray-500"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {% for row in pending %}
      <tr>
        <td class="px-6 py-3 text-sm text-gray-700"><a class="hover:text-indigo-700" href="{{ row.editHref | escape }}">{{ row.name | escape }}</a></td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.organization | escape }}{% if row.jobTitle != blank %} — {{ row.jobTitle | escape }}{% endif %}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.plusGuests | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-500">{{ row.submittedAt | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">
          <div class="flex items-center gap-2">
            <form method="post" action="{{ base | escape }}/{{ row.id }}/convert">
              <button class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Convert to guest</button>
            </form>
            <form method="post" action="{{ base | escape }}/{{ row.id }}/discard">
              <button class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" data-confirm="Discard this registration? The review copy moves to trash.">Discard</button>
            </form>
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="text-sm text-gray-400">No registrations waiting.</p>
  {% endif %}
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg font-bold text-gray-900">Converted</h2>
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ converted | size }}</span>
  </div>
  {% if converted != empty %}
  <table class="w-full text-left text-sm">
    <tbody class="divide-y divide-gray-100">
      {% for row in converted %}
      <tr>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.name | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-500">{{ row.submittedAt | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700"><a class="hover:text-indigo-700" href="/admin/pages/{{ row.convertedGuestId }}/edit">Guest #{{ row.convertedGuestId }}</a></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="text-sm text-gray-400">None converted yet.</p>
  {% endif %}
</div>
