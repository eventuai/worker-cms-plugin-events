<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">← {{ eventName }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ heading }}</h1>
    <p class="mt-1 text-sm text-gray-500" data-all-guests-summary>
      {% if asyncGuests %}<span data-all-guests-summary-text><span data-table-filter-count="guests">{{ initialCount }}</span> {{ "events.views.all_guests.of" | t }} {{ filteredCount }} {{ "events.views.all_guests.matching_guests_rendered" | t }}</span>
      {% else %}<span data-table-filter-count="guests">{{ filteredCount }}</span> {{ "events.views.all_guests.of" | t }} {{ totalCount }} {{ "events.views.all_guests.guests_across_every_list" | t }}{% endif %}
    </p>
  </div>
  <div class="flex flex-wrap gap-2">
    {% if exportHref != blank %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50" title="{{ "events.views.all_guests.export_csv" | t }}" aria-label="{{ "events.views.all_guests.export_csv" | t }}" href="{{ exportHref }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#download"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.all_guests.export_csv" | t }}</span>
    </a>{% endif %}
  </div>
</div>
{% if archived %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ "events.views.all_guests.these_guests_belong_to_an_archived_event_and_are_read_only" | t }}</p>{% endif %}
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash | t }}</p>{% endif %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
  <form class="flex flex-wrap items-center gap-3" method="get" action="{{ listHref }}" data-table-filter-form data-table-filter-target="[data-table-filter='guests']" data-table-filter-count-target="[data-table-filter-count='guests']">
    {% if selectedCustomFieldKey != blank %}<input type="hidden" name="cf" value="{{ selectedCustomFieldKey }}">{% endif %}
    <input class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" style="max-width:22rem" name="q" value="{{ q }}" placeholder="{{ "events.views.all_guests.search_name_email_phone_or_guest_id" | t }}">
    <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="status">
      <option value="">{{ "events.views.all_guests.all_statuses" | t }}</option>
      {% for status in statuses %}<option value="{{ status }}"{% if status == selectedStatus %} selected{% endif %}>{{ status }}</option>{% endfor %}
    </select>
    <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="color">
      <option value="">{{ "events.views.all_guests.all_color_tags" | t }}</option>
      <option value="none"{% if selectedColor == 'none' %} selected{% endif %}>{{ "events.views.all_guests.no_color_tag" | t }}</option>
      {% for color in colorOptions %}<option value="{{ color.value }}"{% if color.selected %} selected{% endif %}>{{ color.label }}</option>{% endfor %}
    </select>
    <button class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50" type="submit" title="{{ "events.views.all_guests.search" | t }}" aria-label="{{ "events.views.all_guests.search_guests" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#search"></use></svg>
    </button>
    <a class="text-sm font-semibold text-gray-500 hover:text-indigo-700" href="{{ listHref }}" data-table-filter-clear{% if q == blank and selectedStatus == blank and selectedColor == blank %} hidden{% endif %}>{{ "events.views.all_guests.clear" | t }}</a>
  </form>
</div>
{% assign allGuestsEmptyMessage = "events.views.all_guests.no_guests_match_filter" | t %}
{% if asyncGuests %}
  <div data-all-guests-async data-total-count="{{ totalCount }}" data-filtered-count="{{ filteredCount }}" data-initial-count="{{ initialCount }}" data-i18n-checked-in="{{ "events.views.all_guests.checked_in" | t }}" data-i18n-not-checked-in="{{ "events.views.all_guests.not_checked_in" | t }}" data-i18n-of="{{ "events.views.all_guests.of" | t }}" data-i18n-matching-rendered="{{ "events.views.all_guests.matching_guests_rendered" | t }}" data-i18n-across-lists="{{ "events.views.all_guests.guests_across_every_list" | t }}" data-i18n-rendering="{{ "events.views.all_guests.rendering" | t }}" data-i18n-render-error="{{ "events.views.all_guests.render_error" | t }}">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-4 mb-4 text-center" data-all-guests-loading role="status" aria-live="polite">
      <span class="inline-block h-6 w-6 animate-spin rounded-full border-2 border-gray-300 border-t-indigo-600" aria-hidden="true"></span>
      <p class="mt-2 text-sm text-gray-500" data-all-guests-progress>{{ "events.views.all_guests.rendering" | t }} {{ initialCount }} {{ "events.views.all_guests.of" | t }} {{ filteredCount }} {{ "events.views.all_guests.matching_guests" | t }}…</p>
    </div>
    <div data-all-guests-table>{% render "guest-table",
      guests: guests,
      statuses: statuses,
      listHref: listHref,
      q: q,
      selectedStatus: selectedStatus,
      selectedColor: selectedColor,
      hasEdm: hasEdm,
      showListColumn: true,
      hasCustomFields: hasCustomFields,
      customFieldOptions: customFieldOptions,
      selectedCustomFieldKey: selectedCustomFieldKey,
      emptyMessage: allGuestsEmptyMessage
    %}</div>
    {% comment %}Plugin HTML sanitization removes every non-approved script element,
    including application/json data blocks. A hidden inert element preserves the
    already script-safe JSON for the approved renderer asset.{% endcomment %}
    <div hidden data-all-guests-json>{{ deferredGuestsJson }}</div>
  </div>
{% else %}
  {% render "guest-table",
    guests: guests,
    statuses: statuses,
    listHref: listHref,
    q: q,
    selectedStatus: selectedStatus,
    selectedColor: selectedColor,
    hasEdm: hasEdm,
    showListColumn: true,
    hasCustomFields: hasCustomFields,
    customFieldOptions: customFieldOptions,
    selectedCustomFieldKey: selectedCustomFieldKey,
    emptyMessage: allGuestsEmptyMessage
  %}
{% endif %}
{% if asyncGuests %}<script src="/admin/plugins/events/assets/all-guests-embedded.js" defer></script>{% endif %}
