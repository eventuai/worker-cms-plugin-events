<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">All guests</h1>
    <p class="mt-1 text-sm text-gray-500">{{ filteredCount }} of {{ totalCount }} guest{% if totalCount != 1 %}s{% endif %} across every list</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportHref | escape }}">Export CSV</a>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
  <form class="flex flex-wrap items-center gap-3" method="get" action="{{ listHref | escape }}">
    <input class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" style="max-width:22rem" name="q" value="{{ q | escape }}" placeholder="Search name, email, phone or guest ID">
    <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="status">
      <option value="">All statuses</option>
      {% for status in statuses %}<option value="{{ status | escape }}"{% if status == selectedStatus %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
    </select>
    <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="color">
      <option value="">All color tags</option>
      <option value="none"{% if selectedColor == 'none' %} selected{% endif %}>No color tag</option>
      {% for color in colorOptions %}<option value="{{ color.value | escape }}"{% if color.selected %} selected{% endif %}>{{ color.label | escape }}</option>{% endfor %}
    </select>
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" type="submit">Filter</button>
    {% if q != blank or selectedStatus != blank or selectedColor != blank %}<a class="text-sm font-semibold text-gray-500 hover:text-indigo-700" href="{{ listHref | escape }}">Clear</a>{% endif %}
  </form>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">List</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organisation</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Check-in</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">{{ guest.name | escape }}</a>{% if guest.color_tag %}<div class="mt-1 inline-flex items-center gap-1 text-xs text-gray-500"><span class="inline-block h-2.5 w-2.5 rounded-full border border-gray-300" style="background-color:{{ guest.color_tag | escape }}"></span>{{ guest.color_tag | escape }}</div>{% endif %}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.listName | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.email | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.organization | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.status | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{% if guest.checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Checked in</span>{% endif %}</td>
          <td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">Edit →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="7" class="px-6 py-10 text-center text-sm text-gray-400">No guests match this filter.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
