<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">Archive event</h1>
    <p class="mt-1 text-sm text-gray-500">{{ guestTotal }} guest(s) reconciled against the contact database. Applying merges each guest's event activity into their contact record, moves this event's RSVP submissions to trash, and hides the event.</p>
  </div>
  <form method="post" action="{{ action | escape }}" data-long-running-form>
    {% if archived %}
    <input type="hidden" name="action" value="unarchive">
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit">Restore event</button>
    {% else %}
    <div class="flex flex-col gap-2 items-end">
      <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit" name="action" value="apply" data-loading-label="Archiving" data-confirm="Merge {{ pendingTotal }} guest(s) into the contact database, move this event's RSVP responses and registrations to trash, and mark the event archived?">Merge &amp; archive</button>
      <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" name="action" value="skip" data-confirm="Archive this event WITHOUT merging guests into contacts or trashing submissions? It will only be hidden from the events list.">Archive only (no merge)</button>
    </div>
    {% endif %}
  </form>
</div>

{% if contactsCapped %}
<p class="mb-4 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-900">The contact database is larger than the reconciliation cap — matching covered the first 2000 contacts only. Guests matching a contact beyond the cap may show as new contacts.</p>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {% for stat in tiles %}
      <div class="border border-gray-200 rounded-lg p-3 text-center"><b class="block text-2xl font-bold text-gray-900">{{ stat.value }}</b><span class="text-xs text-gray-500">{{ stat.label | escape }}</span></div>
    {% endfor %}
  </div>
</div>

{% comment %} Each section is a native <details> so the (often long) guest table
collapses with no client JS. The table sits in a capped-height scroll box so an
expanded section never dominates the page and stays scrollable on narrow screens. {% endcomment %}
{% for section in sections %}
<details class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem"{% if section.count > 0 %} open{% endif %}>
  <summary class="text-lg font-bold text-gray-900" style="cursor:pointer">
    {{ section.label | escape }}
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700" style="margin-left:.5rem;vertical-align:middle">{{ section.count }}</span>
  </summary>
  <p class="mt-2 text-sm text-gray-500 mb-4">{{ section.hint | escape }}</p>
  {% if section.count > 0 %}
  <div style="max-height:24rem;overflow:auto">
    <table class="w-full text-left text-sm">
      <thead>
        <tr class="text-xs text-gray-500">
          <th class="px-6 py-2 font-semibold" style="position:sticky;top:0;background:#fff">Guest</th>
          <th class="px-6 py-2 font-semibold" style="position:sticky;top:0;background:#fff">Guest list</th>
          <th class="px-6 py-2 font-semibold" style="position:sticky;top:0;background:#fff">Email</th>
          <th class="px-6 py-2 font-semibold" style="position:sticky;top:0;background:#fff">Detail</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% for row in section.rows %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ row.name | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ row.listName | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ row.detail | escape }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if section.moreCount > 0 %}
  <p class="mt-2 text-sm text-gray-400">…and {{ section.moreCount }} more not shown.</p>
  {% endif %}
  {% else %}
  <p class="text-sm text-gray-400">None.</p>
  {% endif %}
</details>
{% endfor %}

<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
