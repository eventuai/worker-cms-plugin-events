<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">Archive event</h1>
    <p class="mt-1 text-sm text-gray-500">{{ guestTotal }} guest(s) reconciled against the contact database before closing the event out.</p>
  </div>
  <form method="post" action="{{ action | escape }}">
    {% if archived %}
    <input type="hidden" name="action" value="unarchive">
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit">Restore event</button>
    {% else %}
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit" data-confirm="Archive this event? It will be hidden from the events list.">Mark event archived</button>
    {% endif %}
  </form>
</div>

{% if contactsCapped %}
<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">The contact database is larger than the reconciliation cap — email matching covered the first 2000 contacts only.</p>
{% endif %}

<p class="mt-1 text-sm text-gray-500" style="margin-bottom:1rem">Writing event history back onto contact records isn't done from here — the events plugin has read-only access to contacts.</p>

{% for category in categories %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="margin-bottom:1rem">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-lg font-bold text-gray-900">{{ category.label | escape }}</h2>
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ category.count }}</span>
  </div>
  {% if category.count > 0 %}
  <table class="w-full text-left text-sm">
    <tbody class="divide-y divide-gray-100">
      {% for row in category.rows %}
      <tr>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.name | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.listName | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-700">{{ row.email | escape }}</td>
        <td class="px-6 py-3 text-sm text-gray-500">{{ row.detail | escape }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="text-sm text-gray-400">None.</p>
  {% endif %}
</div>
{% endfor %}
