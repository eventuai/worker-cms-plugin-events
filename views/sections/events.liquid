<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">{{ "events.views.events.events" | t }}</h1><p class="mt-1 text-sm text-gray-500">{{ "events.views.events.manage_events_guests_and_check_in" | t }}</p></div>
  {% if canEdit %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700"
     title="{{ "events.views.events.new_event" | t }}"
     aria-label="{{ "events.views.events.new_event" | t }}"
     href="/admin/pages/new?page_type=event&return_to=%2Fadmin%2Fplugins%2Fevents%2Fevents">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
    <span class="hidden lg:inline">{{ "events.views.events.new_event" | t }}</span>
  </a>{% endif %}
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash }}</p>{% endif %}
<nav class="flex flex-wrap gap-2 mb-4 text-sm">
  <a class="{% if showArchived %}text-gray-500 hover:text-indigo-700{% else %}font-semibold text-indigo-600{% endif %}" href="{{ activeHref }}">{{ "events.views.events.active" | t }}</a>
  <a class="{% if showArchived %}font-semibold text-indigo-600{% else %}text-gray-500 hover:text-indigo-700{% endif %}" href="{{ archivedHref }}">{{ "events.views.events.archived" | t }}</a>
</nav>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.events.name" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.events.start" | t }}</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for event in events %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ event.dashboardHref }}">{{ event.name }}</a>{% if event.deleting %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800">{{ "events.views.events.deleting" | t }}</span>{% endif %}{% if event.archived %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ "events.views.events.archived_2" | t }}</span>{% endif %}</td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ event.start }}</td>
          <td class="px-6 py-3 text-right whitespace-nowrap">
            <div class="inline-flex items-center gap-3">
              {% if event.duplicateHref != blank %}<a class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800" title="{{ "events.views.events.duplicate_event" | t }}" aria-label="{{ "events.views.events.duplicate_event" | t }}" href="{{ event.duplicateHref }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#duplicate"></use></svg></a>{% endif %}
              {% if event.deleteHref != blank %}<a class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-600 hover:bg-red-50 hover:text-red-700" title="{{ "events.views.events.delete_event" | t }}" aria-label="{{ "events.views.events.delete_event" | t }}" href="{{ event.deleteHref }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg></a>{% endif %}
            </div>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="3" class="px-6 py-10 text-center text-sm text-gray-400">{{ "events.views.events.no_events_yet" | t }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
