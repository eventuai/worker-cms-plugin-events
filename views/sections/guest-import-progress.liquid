<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.guest_import_progress.importing_guests" | t }}</h1>
  <p class="mt-1 text-sm text-gray-500">{{ heading }}</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <div class="flex flex-wrap gap-2 mb-4">
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ createdCount }} created this pass</span>
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ updatedCount }} updated this pass</span>
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ remainingLabel }}</span>
  </div>

  {% if auto %}
    <p class="text-sm text-gray-600 mb-4">{{ "events.views.guest_import_progress.this_import_is_large_so_it_runs_in_stages_it_will_continue_automatically" | t }}</p>
  {% else %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ "events.views.guest_import_progress.this_pass_could_not_apply_any_records_press_continue_import_to_retry_if_" | t }}</div>
  {% endif %}

  <form method="post" action="{{ confirmAction }}" id="import-continue-form" data-auto="{% if auto %}1{% else %}0{% endif %}" data-long-running-form>
    <textarea name="csv" style="display:none">{{ csv }}</textarea>
    <input type="hidden" name="mode" value="{{ mode }}">
    <input type="hidden" name="assign_new_ids" value="{{ assignNewIds }}">
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="{{ "events.views.guest_import_progress.continue_import" | t }}" aria-label="{{ "events.views.guest_import_progress.continue_import" | t }}" data-loading-label="{{ "events.views.guest_import_progress.continuing_import" | t }}">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
        <span class="hidden lg:inline">{{ "events.views.guest_import_progress.continue_import" | t }}</span>
      </button>
      <a href="{{ backHref }}" data-stop-continue class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.guest_import_progress.stop_for_now" | t }}</a>
    </div>
  </form>
</div>

<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
<script src="/admin/plugins/events/assets/import-continue.js" defer></script>
