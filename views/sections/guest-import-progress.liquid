<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900">Importing guests…</h1>
  <p class="mt-1 text-sm text-gray-500">{{ heading | escape }}</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <div class="flex flex-wrap gap-2 mb-4">
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ createdCount }} created this pass</span>
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ updatedCount }} updated this pass</span>
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ remainingLabel }}</span>
  </div>

  {% if auto %}
    <p class="text-sm text-gray-600 mb-4">This import is large, so it runs in stages. It will continue automatically — keep this page open until it finishes.</p>
  {% else %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">This pass could not apply any records. Press “Continue import” to retry; if it keeps stopping here, split the file into smaller parts and import them one at a time.</div>
  {% endif %}

  <form method="post" action="{{ confirmAction | escape }}" id="import-continue-form" data-auto="{% if auto %}1{% else %}0{% endif %}" data-long-running-form>
    <textarea name="csv" style="display:none">{{ csv | escape }}</textarea>
    <input type="hidden" name="mode" value="{{ mode | escape }}">
    <input type="hidden" name="assign_new_ids" value="{{ assignNewIds | escape }}">
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="Continue import" aria-label="Continue import" data-loading-label="Continuing import">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
        <span class="hidden lg:inline">Continue import</span>
      </button>
      <a href="{{ backHref | escape }}" data-stop-continue class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Stop for now</a>
    </div>
  </form>
</div>

<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
<script src="/admin/plugins/events/assets/import-continue.js" defer></script>
