<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">EDMs</h1><p class="mt-1 text-sm text-gray-500">Create invitations, preview them, and queue delivery to a guest list.</p></div>
  <a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700"
     title="New EDM"
     aria-label="New EDM"
     href="{{ newHref | escape }}">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
    <span class="hidden lg:inline">New EDM</span>
  </a>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Subject</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Event</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for edm in edms %}
        <tr><td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.href | escape }}">{{ edm.name | escape }}</a></td><td class="px-6 py-3 text-sm text-gray-700">{{ edm.subject | escape }}</td><td class="px-6 py-3 text-sm text-gray-700">{{ edm.eventName | escape }}</td><td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.previewHref | escape }}" target="_blank">Preview ↗</a></td></tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">No EDMs yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
