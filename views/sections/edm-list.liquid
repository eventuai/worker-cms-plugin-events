<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">{{ "events.views.edm_list.edms" | t }}</h1><p class="mt-1 text-sm text-gray-500">{{ "events.views.edm_list.create_invitations_preview_them_and_queue_delivery_to_a_guest_list" | t }}</p></div>
  <a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700"
     title="{{ "events.views.edm_list.new_edm" | t }}"
     aria-label="{{ "events.views.edm_list.new_edm" | t }}"
     href="{{ newHref }}">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
    <span class="hidden lg:inline">{{ "events.views.edm_list.new_edm" | t }}</span>
  </a>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.edm_list.name" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.edm_list.subject" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.edm_list.event" | t }}</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for edm in edms %}
        <tr><td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.href }}">{{ edm.name }}</a></td><td class="px-6 py-3 text-sm text-gray-700">{{ edm.subject }}</td><td class="px-6 py-3 text-sm text-gray-700">{{ edm.eventName }}</td><td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.previewHref }}" target="_blank">{{ "events.views.edm_list.preview" | t }}</a></td></tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">{{ "events.views.edm_list.no_edms_yet" | t }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
