<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventsHref | escape }}">← Events</a><h1 class="text-2xl font-bold text-gray-900">{{ eventName | escape }}</h1></div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ adhocCheckinHref | escape }}">Adhoc check-in</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ guestListsHref | escape }}">Guest lists</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ allGuestsHref | escape }}">All guests</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ sessionsHref | escape }}">Sessions</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ importHref | escape }}">Import</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportAllHref | escape }}">Export all guests</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ labelsHref | escape }}">Labels</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ editHref | escape }}">Edit event ↗</a>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {% for stat in stats %}
      <div class="border border-gray-200 rounded-lg p-3 text-center"><b class="block text-2xl font-bold text-gray-900"{% if stat.color %} style="color:{{ stat.color | escape }}"{% endif %}>{{ stat.value }}</b><span class="text-xs text-gray-500">{{ stat.label | escape }}</span></div>
    {% endfor %}
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mt-4">
  <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
    <div><h2 class="text-lg font-bold text-gray-900">Guest lists</h2><p class="mt-1 text-sm text-gray-500">Invitation, RSVP and check-in summary by list.</p></div>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ newGuestListHref | escape }}">New guest list</a>
  </div>
  <table class="w-full text-left text-sm" data-reorder="{{ reorderAction | escape }}" data-reorder-key="reorder" data-reorder-mode="weight">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest list</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guests</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Invitation</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">RSVP</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Check-in</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for list in guestLists %}
        <tr draggable="true" data-id="{{ list.id }}">
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.href | escape }}">{{ list.name | escape }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-700"><strong>{{ list.summary.guest_count }}</strong> groups<br><span class="text-sm text-gray-500">{{ list.summary.guest_total }} people</span></td>
          <td class="px-6 py-3 text-sm text-gray-700">On hold {{ list.summary.onhold_count }} · To invite {{ list.summary.to_be_invited_count }} · Invited {{ list.summary.invited_count }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">Confirmed {{ list.summary.confirmed_count }} · Declined {{ list.summary.declined_count }}{% if list.summary.unconfirmed_count > 0 %} · Unconfirmed {{ list.summary.unconfirmed_count }}{% endif %}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.summary.checked_in_count }} groups<br><span class="text-sm text-gray-500">{{ list.summary.checked_in_total }} people</span></td>
          <td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.href | escape }}">Manage →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="6" class="px-6 py-10 text-center text-sm text-gray-400">No guest lists yet. Create one to begin inviting guests.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
