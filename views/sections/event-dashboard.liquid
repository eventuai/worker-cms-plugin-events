<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventsHref | escape }}">← Events</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ eventName | escape }}</h1>
  </div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ adhocCheckinHref | escape }}">Adhoc check-in</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ sessionsHref | escape }}">Sessions</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ labelsHref | escape }}">Labels</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ editHref | escape }}">Edit event ↗</a>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {% for stat in stats %}
      <div class="border border-gray-200 rounded-lg p-3 text-center"><b class="block text-2xl font-bold text-gray-900"{% if stat.color %} style="color:{{ stat.color | escape }}"{% endif %}>{{ stat.value }}</b><span class="text-xs text-gray-500">{{ stat.label | escape }}</span></div>
    {% endfor %}
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold bg-white text-gray-700 hover:bg-gray-50" href="{{ allGuestsHref | escape }}">View all guests →</a>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mt-4">
  <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
    <div>
      <a class="hover:underline flex items-center gap-2 text-lg font-bold text-gray-900" href="{{ guestListsHref | escape }}"><svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>Guest lists</a>
    <p class="mt-1 text-sm text-gray-500">Invitation, RSVP and check-in summary by list.</p></div>
    <div>
<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ importHref | escape }}">Import</a>
<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportAllHref | escape }}">Export</a>
<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ newGuestListHref | escape }}">New</a>
    </div>

  </div>
  <table class="w-full text-left text-sm" data-reorder="{{ reorderAction | escape }}" data-reorder-key="updates" data-reorder-mode="weight" data-reorder-event-id="{{ reorderEventId }}" data-reorder-handle-only>
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-4 py-3 w-10"></th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest list</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guests</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Invitation</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">RSVP</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Check-in</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for list in guestLists %}
        <tr data-id="{{ list.id }}">
          <td class="px-4 py-3 text-gray-400" data-reorder-handle title="Drag to reorder" style="cursor:grab"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" d="M9 5h.01M9 12h.01M9 19h.01M15 5h.01M15 12h.01M15 19h.01" /></svg></td>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.href | escape }}">{{ list.name | escape }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-700"><strong>{{ list.summary.guest_count }}</strong> groups<br><span class="text-sm text-gray-500">{{ list.summary.guest_total }} people</span></td>
          <td class="px-6 py-3 text-sm text-gray-700">On hold {{ list.summary.onhold_count }} · To invite {{ list.summary.to_be_invited_count }} · Invited {{ list.summary.invited_count }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">Confirmed {{ list.summary.confirmed_count }} · Declined {{ list.summary.declined_count }}{% if list.summary.unconfirmed_count > 0 %} · Unconfirmed {{ list.summary.unconfirmed_count }}{% endif %}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.summary.checked_in_count }} groups<br><span class="text-sm text-gray-500">{{ list.summary.checked_in_total }} people</span></td>
          <td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.href | escape }}">→</a></td>
        </tr>
      {% else %}
        <tr><td colspan="7" class="px-6 py-10 text-center text-sm text-gray-400">No guest lists yet. Create one to begin inviting guests.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mt-4">
  <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
    <div><h2 class="flex items-center gap-2 text-lg font-bold text-gray-900"><svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>Email templates</h2><p class="mt-1 text-sm text-gray-500">EDM templates for this event's invitations and blasts.</p></div>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ newEdmHref | escape }}">Add template</a>
  </div>
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Subject</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for edm in edms %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.href | escape }}">{{ edm.name | escape }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ edm.subject | escape }}</td>
          <td class="px-6 py-3 text-right whitespace-nowrap"><div class="inline-flex items-center gap-4"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.previewHref | escape }}" target="_blank" rel="noopener">Preview ↗</a><form method="post" action="{{ edm.duplicateAction | escape }}"><button class="border-0 bg-transparent p-0 text-indigo-600 font-medium hover:text-indigo-800 cursor-pointer" type="submit">Duplicate</button></form><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ edm.href | escape }}">Edit →</a></div></td>
        </tr>
      {% else %}
        <tr><td colspan="3" class="px-6 py-10 text-center text-sm text-gray-400">No email templates yet. Add one to invite or blast this event's guests.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mt-4">
  <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
    <div><h2 class="flex items-center gap-2 text-lg font-bold text-gray-900"><svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" /></svg>Guest responses</h2><p class="mt-1 text-sm text-gray-500">Guests who have confirmed or declined, most recent first.</p></div>
    {% if responses.size > 0 %}<span class="text-sm text-gray-500">{{ responses.size }} responses</span>{% endif %}
  </div>
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name / contact</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Response</th>{% if responsesShowCheckin %}<th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Checked-in</th>{% endif %}</tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for row in responses %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700 whitespace-nowrap">{{ row.dateLabel }}<br><span class="text-xs text-gray-500">{{ row.timeLabel }}</span></td>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ row.href | escape }}">{{ row.name | escape }}</a><br><span class="text-xs text-gray-500">{{ row.contact | escape }}</span></td>
          <td class="px-6 py-3 text-sm"><span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {% if row.status == 'confirmed' %}bg-emerald-100 text-emerald-700{% else %}bg-rose-100 text-rose-700{% endif %}">{{ row.status | capitalize }}</span></td>
          {% if responsesShowCheckin %}<td class="px-6 py-3 text-sm text-gray-700">{% if row.checkedIn %}<span class="text-indigo-600 font-medium">Yes</span>{% else %}—{% endif %}</td>{% endif %}
        </tr>
      {% else %}
        <tr><td colspan="{% if responsesShowCheckin %}4{% else %}3{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">No responses yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
