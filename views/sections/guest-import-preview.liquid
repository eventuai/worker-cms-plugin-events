<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ importHref }}">{{ "events.views.guest_import_preview.choose_a_different_file" | t }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.guest_import_preview.preview_import" | t }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ listName }} · {{ eventName }}</p>
  </div>
</div>

<div class="flex flex-wrap gap-2 mb-4">
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ newCount }} new</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ updateCount }} to update</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ unchangedCount }} no change</span>
</div>

{% if limitWarning != '' %}
  <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ limitWarning }}</div>
{% endif %}
{% if creditWarning != '' %}
  <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ creditWarning }}</div>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mb-4">
  <table class="w-full min-w-[560px] text-left relative" data-privacy-table>
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_import_preview.name" | t }}</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_import_preview.email" | t }}</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_import_preview.record" | t }}</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_import_preview.changes" | t }}</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="name">{{ guest.name }}</span></td>
          <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="email">{{ guest.email }}</span></td>
          <td class="px-6 py-3 text-sm">
            {% if guest.state == 'new' %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ "events.views.guest_import_preview.new" | t }}</span>
            {% elsif guest.state == 'update' %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ "events.views.guest_import_preview.update" | t }}</span>
            {% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ "events.views.guest_import_preview.no_change" | t }}</span>{% endif %}
          </td>
          <td class="px-6 py-3 text-sm text-gray-600">
            {% if guest.changes.size > 0 %}
              <ul>
                {% for change in guest.changes %}
                  <li>{% if change.add %}<span class="text-green-700">+ {{ change.label }}:</span> {{ change.to }}{% else %}<span class="text-amber-700">{{ change.label }}:</span> <span class="text-gray-400">{{ change.from }}</span> → {{ change.to }}{% endif %}</li>
                {% endfor %}
              </ul>
            {% else %}<span class="text-gray-400">—</span>{% endif %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<form method="post" action="{{ confirmAction }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" data-long-running-form>
  <textarea name="csv" style="display:none">{{ csv }}</textarea>
  <label class="block mb-4" style="max-width:30rem">
    <span class="block text-sm font-medium text-gray-700 mb-1">{{ "events.views.guest_import_preview.how_should_these_be_imported" | t }}</span>
    <select name="mode" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="new_and_update">{{ "events.views.guest_import_preview.import_new_records_and_update_existing_records" | t }}</option>
      <option value="new_only">{{ "events.views.guest_import_preview.import_new_records_only" | t }}</option>
      <option value="update_only">{{ "events.views.guest_import_preview.update_existing_records_only" | t }}</option>
    </select>
  </label>
  <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="{{ "events.views.guest_import_preview.confirm_import" | t }}" aria-label="{{ "events.views.guest_import_preview.confirm_import" | t }}" data-loading-label="{{ "events.views.guest_import_preview.importing_guests" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_import_preview.confirm_import" | t }}</span>
    </button>
    <a href="{{ listHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.guest_import_preview.cancel" | t }}</a>
  </div>
</form>
<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
