<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ importHref | escape }}">← Choose a different file</a>
    <h1 class="text-2xl font-bold text-gray-900">Preview import</h1>
    <p class="mt-1 text-sm text-gray-500">{{ listName | escape }} · {{ eventName | escape }}</p>
  </div>
</div>

<div class="flex flex-wrap gap-2 mb-4">
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ newCount }} new</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ updateCount }} to update</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ unchangedCount }} no change</span>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mb-4">
  <table class="w-full min-w-[560px] text-left">
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Record</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Changes</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.name | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.email | escape }}</td>
          <td class="px-6 py-3 text-sm">
            {% if guest.state == 'new' %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">New</span>
            {% elsif guest.state == 'update' %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">Update</span>
            {% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">No change</span>{% endif %}
          </td>
          <td class="px-6 py-3 text-sm text-gray-600">
            {% if guest.changes.size > 0 %}
              <ul>
                {% for change in guest.changes %}
                  <li>{% if change.add %}<span class="text-green-700">+ {{ change.label | escape }}:</span> {{ change.to | escape }}{% else %}<span class="text-amber-700">{{ change.label | escape }}:</span> <span class="text-gray-400">{{ change.from | escape }}</span> → {{ change.to | escape }}{% endif %}</li>
                {% endfor %}
              </ul>
            {% else %}<span class="text-gray-400">—</span>{% endif %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<form method="post" action="{{ confirmAction | escape }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <textarea name="csv" style="display:none">{{ csv | escape }}</textarea>
  <label class="block mb-4" style="max-width:30rem">
    <span class="block text-sm font-medium text-gray-700 mb-1">How should these be imported?</span>
    <select name="mode" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="new_and_update">Import new records and update existing records</option>
      <option value="new_only">Import new records only</option>
      <option value="update_only">Update existing records only</option>
    </select>
  </label>
  <div class="flex items-center gap-3">
    <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer">Confirm import</button>
    <a href="{{ listHref | escape }}" class="text-sm text-gray-500 hover:text-gray-700">Cancel</a>
  </div>
</form>
