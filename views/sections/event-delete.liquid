<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">← {{ eventName }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.event_delete.delete_event" | t }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ "events.views.event_delete.move" | t }} <strong>{{ eventName }}</strong> {{ "events.views.event_delete.to_trash" | t }}</p>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:40rem">
  <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
    <p class="font-semibold">{{ "events.views.event_delete.this_will_also_delete_everything_under_the_event" | t }}</p>
    <ul class="mt-2 list-disc ps-4">
      <li>{{ listCount }} guest list{% unless listCount == 1 %}s{% endunless %} and all of their guests</li>
      <li>{{ edmCount }} email template{% unless edmCount == 1 %}s{% endunless %}</li>
    </ul>
    <p class="mt-2">{{ "events.views.event_delete.deleted_items_move_to_the_cms_trash_and_can_be_restored_from_there" | t }}</p>
  </div>
  <form method="post" action="{{ action }}" data-long-running-form>
    <div class="flex flex-wrap items-center gap-2">
      <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-red-600 px-4 text-sm font-semibold text-white hover:bg-red-700 cursor-pointer" type="submit" title="{{ "events.views.event_delete.delete_event" | t }}" aria-label="{{ "events.views.event_delete.delete_event" | t }}" data-loading-label="{{ "events.views.event_delete.deleting_event" | t }}">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg>
        <span>{{ "events.views.event_delete.delete_event" | t }}</span>
      </button>
      <a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50" href="{{ backHref }}">{{ "events.views.event_delete.cancel" | t }}</a>
    </div>
  </form>
</div>
<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
