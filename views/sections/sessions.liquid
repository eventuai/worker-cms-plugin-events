<div class="ev-head">
  <div>
    <a class="ev-back" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="ev-h1">Sessions</h1>
    <p class="ev-sub">Drag a session to reorder it. Edit session details on the event page.</p>
  </div>
  <div class="ev-actions">
    <a class="ev-btn ev-btn-secondary" href="{{ editHref | escape }}">Edit event ↗</a>
  </div>
</div>
<div class="ev-card">
  <table class="ev-table" data-reorder="{{ reorderAction | escape }}" data-reorder-key="order" data-reorder-mode="order">
    <thead><tr><th style="width:2rem"></th><th>Session</th><th>Starts</th><th>Location</th><th>Capacity</th></tr></thead>
    <tbody>
      {% for session in sessions %}
        <tr draggable="true" data-index="{{ session.index }}">
          <td class="ev-drag" title="Drag to reorder" style="cursor:grab">⠿</td>
          <td>{{ session.name | escape }}</td>
          <td>{{ session.start | escape }}</td>
          <td>{{ session.location | escape }}</td>
          <td>{{ session.capacity | escape }}</td>
        </tr>
      {% else %}
        <tr><td colspan="5" class="ev-empty">This event has no sessions yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
