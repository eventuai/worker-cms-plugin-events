<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventHref | escape }}">← {{ eventName | escape }}</a><h1 class="text-2xl font-bold text-gray-900">Adhoc check-in</h1></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:32rem">
  <form method="post">
    {% for field in fields %}
      <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ field.label | escape }}</span>
        <input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="{{ field.name | escape }}" type="{{ field.type | escape }}"></label>
    {% endfor %}
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Add &amp; check in</button>
  </form>
</div>
