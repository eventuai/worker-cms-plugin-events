<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "events.views.label_editor.label_templates" | t }}</a>
    <input id="label-name" form="labelSaveForm" class="block w-full border-0 p-0 bg-transparent text-2xl font-bold text-gray-900 focus:outline-none focus:ring-0" name="name" value="{{ labelName }}" required autocomplete="off" placeholder="{{ "events.views.label_editor.template_name" | t }}" aria-label="{{ "events.views.label_editor.template_name" | t }}">
    <p class="mt-1 text-sm text-gray-500">{{ eventName }}</p>
  </div>
  <div class="flex flex-wrap items-center justify-end gap-2">
    <button type="submit" form="labelSaveForm" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="{{ "events.views.label_editor.save_label" | t }}" aria-label="{{ "events.views.label_editor.save_label" | t }}"><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><use href="/assets/icons.svg#check-circle"></use></svg><span id="saveButtonText" class="hidden lg:inline">{{ "events.views.label_editor.save" | t }}</span></button>
    <button type="button" id="exportLabel" hidden class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" title="{{ "events.views.label_editor.export_json" | t }}" aria-label="{{ "events.views.label_editor.export_json" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#download"></use></svg><span class="hidden lg:inline">{{ "events.views.label_editor.export_json" | t }}</span></button>
    <button type="button" id="importLabel" hidden class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" title="{{ "events.views.label_editor.import_json" | t }}" aria-label="{{ "events.views.label_editor.import_json" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg><span class="hidden lg:inline">{{ "events.views.label_editor.import_json" | t }}</span></button>
    <input type="file" id="labelFileInput" accept=".json,.txt" hidden>
    {% if isPublished %}<form method="post" action="{{ unpublishAction }}" data-confirm="{{ "events.views.label_editor.unpublish_this_label_template" | t }}"><button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-yellow-300 bg-white px-4 text-sm font-semibold text-yellow-700 hover:bg-yellow-50 hover:text-yellow-800 cursor-pointer" title="{{ "events.views.label_editor.unpublish_label" | t }}" aria-label="{{ "events.views.label_editor.unpublish_label" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#eye-off"></use></svg><span class="hidden lg:inline">{{ "events.views.label_editor.unpublish" | t }}</span></button></form>{% else %}<form method="post" action="{{ publishAction }}"><button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-green-300 bg-white px-4 text-sm font-semibold text-green-700 hover:bg-green-50 hover:text-green-800 cursor-pointer" title="{{ "events.views.label_editor.publish_label" | t }}" aria-label="{{ "events.views.label_editor.publish_label" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#cloud-upload"></use></svg><span class="hidden lg:inline">{{ "events.views.label_editor.publish" | t }}</span></button></form>{% endif %}
    <form method="post" action="{{ deleteAction }}" data-confirm="{{ "events.views.label_editor.delete_label" | t }} “{{ labelName }}”?"><button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-red-300 bg-white px-4 text-sm font-semibold text-red-600 hover:bg-red-50 hover:text-red-700 cursor-pointer" title="{{ "events.views.label_editor.delete_label" | t }}" aria-label="{{ "events.views.label_editor.delete_label" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg><span class="hidden lg:inline">{{ "events.views.label_editor.delete" | t }}</span></button></form>
  </div>
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash }}</p>{% endif %}
<p id="labelEditorFallback" class="mb-4 rounded-lg bg-amber-50 border border-gray-200 px-4 py-3 text-sm text-amber-800">{{ "events.views.label_editor.the_interactive_label_editor_script_is_not_loaded_it_may_be_awaiting_app" | t }}</p>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 items-start">
  <!-- Preview column -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <form method="get" action="{{ selfHref }}" id="labelGuestForm" class="mb-3">
      <div class="flex gap-2 mb-2">
        <input type="search" name="q" id="guestSearchInput" value="{{ q }}" placeholder="{{ "events.views.label_editor.search_guest_by_name_email_or_organization" | t }}" aria-label="{{ "events.views.label_editor.search_guests" | t }}" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <button type="submit" class="inline-flex h-9 items-center justify-center rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.search" | t }}</button>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <select name="list" id="guestListSelect" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
          <option value="">{{ "events.views.label_editor.preview_guest_list" | t }}</option>
          {% for list in guestLists %}<option value="{{ list.id }}"{% if list.selected %} selected{% endif %}>{{ list.name }}</option>{% endfor %}
        </select>
        <select name="guest" id="guestSelect" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"{% if selectedListId == blank and q == blank %} disabled{% endif %}>
          <option value="">{% if q != blank %}{% if guests.size > 0 %}{{ guests.size }} {{ "events.views.label_editor.matching_guests" | t }}…{% else %}{{ "events.views.label_editor.no_guests_match" | t }} “{{ q }}”{% endif %}{% else %}{{ "events.views.label_editor.preview_guest" | t }}…{% endif %}</option>
          {% for guest in guests %}<option value="{{ guest.id }}"{% if guest.selected %} selected{% endif %}>{{ guest.name }}</option>{% endfor %}
        </select>
        <button type="submit" id="loadGuestButton" class="inline-flex h-9 items-center justify-center rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.load" | t }}</button>
      </div>
    </form>
    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
      <p class="text-sm text-gray-600">{{ "events.views.label_editor.actual_size" | t }} <span id="actualSize" class="font-semibold text-indigo-600">{{ "events.views.label_editor.60mm_30mm" | t }}</span></p>
      <div class="flex items-center gap-3">
        <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-600"><input type="checkbox" id="rotatePreview" class="h-4 w-4">{{ "events.views.label_editor.rotate_90" | t }}</label>
        <button type="button" id="printLabelButton" hidden class="inline-flex h-9 items-center justify-center rounded-lg border border-transparent bg-indigo-600 px-3 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer">{{ "events.views.label_editor.print_label" | t }}</button>
      </div>
    </div>
    <p class="mb-3 text-right text-xs text-gray-500">{{ "events.views.label_editor.uses_the_shared_check_in_printer_mode" | t }} <a href="{{ printerSettingsHref }}" class="font-medium text-indigo-600 hover:text-indigo-800">{{ "events.views.label_editor.printer_settings" | t }}</a></p>
    <div id="svgPreviewContainer" class="flex justify-center items-center rounded-lg p-4 w-full overflow-x-auto" style="min-height:20rem;background-image:linear-gradient(45deg,#e5e7eb 25%,transparent 25%),linear-gradient(-45deg,#e5e7eb 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#e5e7eb 75%),linear-gradient(-45deg,transparent 75%,#e5e7eb 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0;">
      <div id="svgWrapper" class="relative" style="transition:transform .2s">
        <div class="pointer-events-none absolute top-0 left-0 w-full h-full" aria-hidden="true">
          <div class="absolute top-0 left-0 w-full h-full flex justify-center"><div style="width:1px;height:100%;background:#1d4ed8;opacity:.1"></div></div>
          <div class="absolute top-0 left-0 w-full h-full flex items-center"><div style="height:1px;width:100%;background:#1d4ed8;opacity:.1"></div></div>
        </div>
        <div style="border:12px solid #fff;border-bottom-width:24px">
          <svg id="labelSvg" xmlns="http://www.w3.org/2000/svg" style="cursor:crosshair;display:block" data-i18n-text="{{ "events.views.label_editor.text_2" | t }}" data-i18n-image="{{ "events.views.label_editor.image_2" | t }}" data-i18n-rectangle="{{ "events.views.label_editor.rectangle_name" | t }}" data-i18n-ellipse="{{ "events.views.label_editor.ellipse_name" | t }}" data-i18n-qr="{{ "events.views.label_editor.qr_code_2" | t }}" data-i18n-label-absolute="{{ "events.views.label_editor.label_absolute" | t }}" data-i18n-no-element="{{ "events.views.label_editor.no_element_selected" | t }}">
            <rect id="labelBackground"></rect>
            <g id="textElementsGroup"></g>
          </svg>
        </div>
      </div>
    </div>
    <p class="mt-2 text-xs text-gray-400">{{ "events.views.label_editor.click_an_element_to_select_it_drag_to_move_arrow_keys_nudge_hold_shift_f" | t }}</p>
    <textarea id="labelTokens" hidden readonly>{{ tokensJson }}</textarea>

    <!-- Adhoc values -->
    <div id="adhocValuesPanel" class="mt-4 border-t border-gray-200 pt-4" hidden>
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-800">{{ "events.views.label_editor.placeholder_values" | t }}</h3>
        <button type="button" id="clearAdhocValues" class="px-3 py-1 text-xs rounded-lg border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 cursor-pointer">{{ "events.views.label_editor.clear_overrides" | t }}</button>
      </div>
      <p class="text-xs text-gray-500 mb-2">{{ "events.views.label_editor.override" | t }} <code>[@placeholder]</code> {{ "events.views.label_editor.values_to_preview_without_picking_a_guest" | t }}</p>
      <div id="adhocInputsContainer" class="space-y-2"></div>
    </div>

    {% if selectedListId != blank %}
    <section id="batchPrintPanel" data-storage-key="{{ batchStorageKey }}" class="mt-4 border-t border-gray-200 pt-4">
      <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
        <div>
          <h3 class="text-sm font-semibold text-gray-800">{{ "events.views.label_editor.batch_print" | t }}</h3>
          <p id="batchPrintStatus" class="text-xs text-gray-500">{{ "events.views.label_editor.select_guests_from_this_list" | t }}</p>
        </div>
        {% if batchGuests.size > 0 %}<button type="button" id="batchCheckAllButton" class="px-3 py-1 text-xs rounded-lg border border-gray-300 bg-white hover:bg-gray-50 text-gray-700 cursor-pointer">{{ "events.views.label_editor.check_all" | t }}</button>{% endif %}
      </div>
      {% if batchGuests.size > 0 %}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 max-h-64 overflow-y-auto rounded-lg border border-gray-200 p-3">
        {% for guest in batchGuests %}
        <div>
          <label class="flex items-start gap-2 text-sm text-gray-700 cursor-pointer">
            <input type="checkbox" class="batch-guest-checkbox h-4 w-4 mt-0.5" data-guest-id="{{ guest.id }}">
            <span>{{ guest.name }}</span>
          </label>
          <textarea hidden readonly data-batch-tokens="{{ guest.id }}">{{ guest.tokensJson }}</textarea>
        </div>
        {% endfor %}
      </div>
      <button type="button" id="batchPrintButton" class="mt-3 inline-flex h-9 items-center justify-center rounded-lg border border-transparent bg-emerald-600 px-3 text-sm font-semibold text-white hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer" disabled>{{ "events.views.label_editor.batch_print" | t }}</button>
      {% else %}
      <p class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-500">{{ "events.views.label_editor.this_guest_list_is_empty" | t }}</p>
      {% endif %}
    </section>
    {% endif %}
  </div>

  <!-- Controls column -->
  <div class="space-y-4">
    <form method="post" action="{{ action }}" id="labelSaveForm" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <textarea name="design" id="labelDesignField" hidden readonly>{{ designJson }}</textarea>
      <input type="hidden" name="q" value="{{ q }}">
      <input type="hidden" name="list" value="{{ selectedListId }}">
      <input type="hidden" name="guest" value="{{ selectedGuestId }}">
      <input type="hidden" id="selectedGuestName" value="{{ selectedGuestName }}">
      <p id="unsavedHint" class="mt-2 text-xs text-amber-800" hidden>{{ "events.views.label_editor.unsaved_changes_click_save_to_store_this_design" | t }}</p>
    </form>

    <div id="labelControls" hidden>
      <!-- Elements panel -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
        <h3 class="text-sm font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200">{{ "events.views.label_editor.elements" | t }}</h3>
        <div class="flex flex-wrap gap-2 mb-3">
          <button type="button" id="addTextBox" class="px-3 py-1.5 text-sm rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer">{{ "events.views.label_editor.text" | t }}</button>
          <button type="button" id="addQRCode" class="px-3 py-1.5 text-sm rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer">{{ "events.views.label_editor.qr_code" | t }}</button>
          <button type="button" id="addRectangle" class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.rectangle" | t }}</button>
          <button type="button" id="addCircle" class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.ellipse" | t }}</button>
          <button type="button" id="addImage" class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.image" | t }}</button>
          <input type="file" id="imageInput" accept="image/*" hidden>
        </div>
        <div class="flex gap-2 mb-3">
          <input type="text" id="imageUrlInput" placeholder="{{ "events.views.label_editor.or_image_url" | t }}" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm">
          <button type="button" id="addImageUrl" class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 cursor-pointer">{{ "events.views.label_editor.add" | t }}</button>
        </div>
        <div class="flex gap-2">
          <select id="elementSelector" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm"><option value="">{{ "events.views.label_editor.no_element_selected" | t }}</option></select>
          <button type="button" id="removeTextBox" class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white text-red-600 hover:bg-gray-50 cursor-pointer" hidden>{{ "events.views.label_editor.remove" | t }}</button>
        </div>
      </div>

      <!-- Position panel -->
      <div id="positionPanel" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4" hidden>
        <h3 class="text-sm font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200">{{ "events.views.label_editor.position" | t }}</h3>
        <div class="grid grid-cols-2 gap-2 mb-2">
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.relative_to" | t }}</span>
            <select id="parentElement" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"><option value="label">{{ "events.views.label_editor.label_absolute" | t }}</option></select>
          </label>
          <div class="flex" style="align-items:flex-end"><button type="button" id="clearParent" class="px-3 py-2 text-sm rounded-lg border border-gray-300 bg-white hover:bg-gray-50 text-gray-600 cursor-pointer" title="{{ "events.views.label_editor.reset_to_absolute" | t }}">{{ "events.views.label_editor.reset" | t }}</button></div>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.x_anchor" | t }}</span>
            <select id="anchorX" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"><option value="left">{{ "events.views.label_editor.left" | t }}</option><option value="center">{{ "events.views.label_editor.center" | t }}</option><option value="right">{{ "events.views.label_editor.right" | t }}</option></select>
          </label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.y_anchor" | t }}</span>
            <select id="anchorY" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"><option value="top">{{ "events.views.label_editor.top" | t }}</option><option value="middle">{{ "events.views.label_editor.middle" | t }}</option><option value="bottom">{{ "events.views.label_editor.bottom" | t }}</option></select>
          </label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.x_offset_px" | t }}</span><input type="number" id="textX" step="1" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.y_offset_px" | t }}</span><input type="number" id="textY" step="1" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
        </div>
        <p class="text-xs text-gray-400">{{ "events.views.label_editor.offsets_are_from_the_parent_s_anchor_point_use_a_bottom_anchor_to_sit_be" | t }}</p>
      </div>

      <!-- Text settings -->
      <div id="textSettings" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4" hidden>
        <h3 class="text-sm font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-200">{{ "events.views.label_editor.text_2" | t }}</h3>
        <label class="block mb-3"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.content_use_name_organization_and_for_alternatives" | t }}</span><textarea id="labelText" rows="3" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono"></textarea></label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-2">
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.font_size" | t }}</span><input type="number" id="fontSize" min="4" max="200" value="16" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.2nd_size" | t }}</span><input type="number" id="fontSizeSecondary" min="0" max="200" value="0" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.3rd_size" | t }}</span><input type="number" id="fontSizeTertiary" min="0" max="200" value="0" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.leading_em" | t }}</span><input type="number" id="lineHeight" min="0.5" max="5" value="1.2" step="0.1" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.max_width_px" | t }}</span><input type="number" id="maxWidth" min="0" max="5000" value="0" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
          <label class="block"><span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.max_lines" | t }}</span><input type="number" id="maxLines" min="0" max="20" value="0" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></label>
        </div>
        <p class="text-xs text-gray-400 mb-3">{{ "events.views.label_editor.wraps_at_max_width_if_lines_exceed_max_lines_it_retries_with_the_2nd_the" | t }}</p>
        <div class="flex flex-wrap gap-4 mb-3">
          <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700"><input type="checkbox" id="autoSplitCJKLatin" class="h-4 w-4">{{ "events.views.label_editor.auto_linebreak_cjk_latin" | t }}</label>
          <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700"><input type="checkbox" id="balanceOrphans" class="h-4 w-4">{{ "events.views.label_editor.balance_orphan_lines" | t }}</label>
        </div>
        <div class="mb-3">
          <span class="block text-xs text-gray-500 mb-1">{{ "events.views.label_editor.fonts_primary_secondary_tertiary_unicode_range" | t }}</span>
          <div class="grid grid-cols-2 gap-2 mb-1">
            <input type="text" id="fontFamily" list="fontFamilyList" value="Arial" placeholder="{{ "events.views.label_editor.primary_font" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <input type="text" id="fontUnicodePrimary" list="unicodeRangeList" placeholder="{{ "events.views.label_editor.u_4e00_9fff" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            <input type="text" id="fontFamilySecondary" list="fontFamilyList" placeholder="{{ "events.views.label_editor.secondary_font" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <input type="text" id="fontUnicodeSecondary" list="unicodeRangeList" placeholder="{{ "events.views.label_editor.u_0000_00ff" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            <input type="text" id="fontFamilyTertiary" list="fontFamilyList" placeholder="{{ "events.views.label_editor.tertiary_font" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <input type="text" id="fontUnicodeTertiary" list="unicodeRangeList" placeholder="{{ "events.views.label_editor.u_3040_30ff" | t }}" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">
          </div>
          <datalist id="fontFamilyList">
