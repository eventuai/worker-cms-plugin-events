<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventHref | escape }}">← {{ eventName | escape }}</a><h1 class="text-2xl font-bold text-gray-900">All guests ({{ total }})</h1></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">In</th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">{{ guest.name | escape }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.email | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700"><span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ guest.status | escape }}</span></td>
          <td class="px-6 py-3 text-sm text-gray-700">{% if guest.checkedIn %}✅{% endif %}</td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">No guests yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
