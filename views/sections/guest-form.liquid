<div class="flex items-center justify-between gap-4 mb-4" style="max-width:48rem">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref | escape }}">← {{ listName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ title | escape }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ eventName | escape }}</p>
  </div>
  <div class="flex flex-col md:flex-row md:items-center gap-4">
    {% if updateFromContactAction %}
      <form method="post" action="{{ updateFromContactAction | escape }}" onsubmit="return confirm('Overwrite this guest with its linked contact record?')">
        <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" title="Update from contact" aria-label="Update from contact"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#user"></use></svg><span class="hidden lg:inline">Update from contact</span></button>
      </form>
    {% endif %}
  </div>
</div>

<form id="guest-form" method="post" action="{{ action | escape }}">
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    {% if nativePageAction %}
      <input type="hidden" name="page_type" value="guest">
      <input type="hidden" name="slug" value="{{ slug | escape }}">
      <input type="hidden" name="weight" value="{{ weight }}">
      <input type="hidden" name="page_id" value="{{ pageId }}">
      <input type="hidden" name="*mail_list" value="{{ pageId }}">
      {% if eventId %}<input type="hidden" name="*event" value="{{ eventId }}">{% endif %}
    {% endif %}
    {% if returnTo %}<input type="hidden" name="return_to" value="{{ returnTo | escape }}">{% endif %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in detailFields %}
        <div class="{{ field.span | escape }}">
          {% render "render-field", field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">Contact</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in contactFields %}
        <div class="{{ field.span | escape }}">
          {% render "render-field", field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">RSVP</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in rsvpFields %}
        <div class="{{ field.span | escape }}">
          {% render "render-field", field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">Notes</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in noteFields %}
        <div class="{{ field.span | escape }}">
          {% render "render-field", field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">Ticket codes</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in ticketFields %}
        <div class="{{ field.span | escape }}">
          {% render "render-field", field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if hasAdminCustomFields %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
      <h2 class="text-lg font-bold text-gray-900">Additional information</h2>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
        {% for field in adminCustomFields %}
          <div class="{% if field.type == 'textarea' or field.type == 'radio' %}md:col-span-2{% endif %}">
            {% render "render-field", field: field %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</form>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:48rem">
  {% if moveLists.size > 0 %}
    <form method="post" action="{{ moveAction | escape }}" class="flex flex-wrap items-center gap-1.5" style="margin-top:1rem">
      <label class="block" style="margin:0"><span class="block text-sm text-gray-700 mb-1">Move to list</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="target_mail_list">
        <option value="">Select a list</option>
        {% for list in moveLists %}<option value="{{ list.id }}">{{ list.name | escape }}</option>{% endfor %}</select></label><button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" title="Move guest" aria-label="Move guest"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#user-group"></use></svg><span class="hidden lg:inline">Move guest</span></button></form>{% endif %}
  {% if deleteAction %}<form id="guest-delete-form" method="post" action="{{ deleteAction | escape }}" data-confirm="Delete this guest?"></form>{% endif %}
  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button form="guest-form" type="submit" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Save guest</button>
    <a href="{{ listHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
    {% if qrHref %}<a href="{{ qrHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">QR code</a>{% endif %}
    {% if deleteAction %}<button form="guest-delete-form" type="submit" class="w-full px-6 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition-colors shadow-sm sm:ml-auto sm:w-auto">Delete</button>{% endif %}
  </div>
</div>

{% if deleteAction %}
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-4" style="max-width:48rem">
  <h2 class="text-lg font-bold text-gray-900">Activity</h2>
  {% if hasActivity %}
    <div class="mt-4 divide-y divide-gray-100">
      {% for item in activity %}
        <div class="grid grid-cols-1 sm:grid-cols-[10rem_1fr] gap-2 py-3">
          <div class="text-xs text-gray-500 sm:text-right">
            {% if item.date != blank %}{{ item.date | date: "%Y-%m-%d %H:%M" | default: item.date }}{% else %}No date{% endif %}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-block rounded px-2 py-0.5 text-xs font-semibold {% if item.kind == 'edm' %}bg-blue-50 text-blue-700{% elsif item.kind == 'checkin' %}bg-green-50 text-green-700{% else %}bg-gray-100 text-gray-700{% endif %}">{{ item.label | escape }}</span>
              {% if item.status != blank %}<span class="text-sm font-semibold text-gray-900">{{ item.status | capitalize | escape }}</span>{% endif %}
            </div>
            {% if item.message != blank %}<div class="mt-1 text-xs text-gray-500">{{ item.message | escape }}</div>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="mt-3 text-sm text-gray-500">No activity yet.</p>
  {% endif %}
</div>
{% endif %}
