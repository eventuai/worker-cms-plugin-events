<div class="flex items-center justify-between gap-4 mb-4" style="max-width:48rem">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref }}">← {{ listName }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{% if titleKey != blank %}{{ titleKey | t }}{% else %}{{ title }}{% endif %}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ eventName }}</p>
  </div>
  <div class="flex flex-col md:flex-row md:items-center gap-4">
    {% if cmsEditPresence.pageId != blank %}
      <div id="presence-bar"
           class="flex items-center gap-1.5 shrink-0"
           data-page-id="{{ cmsEditPresence.pageId }}"
           data-user-id="{{ cmsEditPresence.currentUserId }}"
           data-user-avatar="{{ cmsEditPresence.userAvatar }}">
        <div id="presence-avatars" class="flex items-center gap-1"></div>
        <div id="sync-indicator"
             title=""
             style="width:8px;height:8px;border-radius:50%;background:#9ca3af;flex-shrink:0;transition:background .4s,opacity .4s;display:none"></div>
      </div>
    {% endif %}
    {% if updateFromContactAction != blank %}
      <form method="post" action="{{ updateFromContactAction }}" onsubmit="return confirm('{{ "events.views.guest_form.overwrite_from_contact" | t }}')">
        <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" title="{{ "events.views.guest_form.update_from_contact" | t }}" aria-label="{{ "events.views.guest_form.update_from_contact" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#user"></use></svg><span class="hidden lg:inline">{{ "events.views.guest_form.update_from_contact" | t }}</span></button>
      </form>
    {% endif %}
  </div>
</div>

{% if readOnly %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700" style="max-width:48rem">{{ "events.views.guest_form.this_guest_belongs_to_an_archived_event_and_is_read_only" | t }}</p>{% endif %}
<form id="guest-form" method="post" action="{{ action }}"{% if nativePageAction %} data-editor-form{% endif %}>
    {% if nativePageAction %}
      <input type="hidden" name="page_type" value="guest">
      <input type="hidden" name="slug" value="{{ slug }}">
      <input type="hidden" name="weight" value="{{ weight }}">
      <input type="hidden" name="page_id" value="{{ pageId }}">
      <input type="hidden" name="*mail_list" value="{{ pageId }}">
      {% if eventId %}<input type="hidden" name="*event" value="{{ eventId }}">{% endif %}
      {% if guest.contact != blank %}<input type="hidden" name="*contact" value="{{ guest.contact }}">{% endif %}
    {% endif %}
    {% if returnTo %}<input type="hidden" name="return_to" value="{{ returnTo }}">{% endif %}
    <fieldset{% if readOnly %} disabled{% endif %} style="border:0;padding:0;margin:0;min-width:0">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in detailFields %}
        <div class="{{ field.span }}">
          {% render field.templateName, field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.contact" | t }}</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in contactFields %}
        <div class="{{ field.span }}">
          {% render field.templateName, field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.rsvp" | t }}</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in rsvpFields %}
        <div class="{{ field.span }}">
          {% render field.templateName, field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if companionOf %}
    <div class="bg-indigo-50 rounded-xl border border-indigo-100 p-4 mb-4" style="max-width:48rem">
      <p class="text-sm text-indigo-900">{{ "events.views.guest_form.named_companion_of" | t }} <a class="font-semibold underline" href="{{ companionOf.editHref }}">{{ companionOf.name }}</a>.</p>
      {% if hasCompanionAnswers %}
        <dl class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2">
          {% for answer in companionAnswers %}<div><dt class="text-xs font-medium text-indigo-600">{{ answer.label }}</dt><dd class="mt-0.5 text-sm text-indigo-950">{{ answer.value }}</dd></div>{% endfor %}
        </dl>
      {% endif %}
    </div>
  {% endif %}

  {% if hasLinkedCompanions %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
      <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.named_companion_guests" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "events.views.guest_form.each_named_companion_has_an_independent_guest_record_qr_code_rsvp_detail" | t }}</p>
      <div class="mt-4 divide-y divide-gray-100">
        {% for companion in linkedCompanions %}
          <div class="flex flex-wrap items-center justify-between gap-3 py-3 first:pt-0 last:pb-0">
            <div>
              <p class="text-sm font-semibold text-gray-900">{{ companion.name }}</p>
              {% if companion.organization != blank %}<p class="text-xs text-gray-500">{{ companion.organization }}</p>{% endif %}
            </div>
            <div class="flex items-center gap-3 text-xs font-semibold">
              <a class="text-indigo-600 hover:text-indigo-800" href="{{ companion.editHref }}">{{ "events.views.guest_form.edit" | t }}</a>
              <a class="text-indigo-600 hover:text-indigo-800" href="{{ companion.qrHref }}">{{ "events.views.guest_form.qr_code" | t }}</a>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if hasPlusGuests %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
      <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.unnamed_plus_guests" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "events.views.guest_form.names_are_optional_unnamed_rows_still_reserve_a_companion_place_and_qr_c" | t }}</p>
      <div class="mt-4 divide-y divide-gray-100">
        {% for plus in plusGuests %}
          <div class="py-4 first:pt-0 last:pb-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-gray-100 text-xs font-semibold text-gray-600">{{ plus.number }}</span>
              <span class="text-sm font-semibold text-gray-900">{% if plus.name != blank %}{{ plus.name }}{% else %}{{ "events.views.guest_form.unnamed_plus_guest" | t }}{% endif %}</span>
            </div>
            {% if plus.organization != blank %}<p class="mt-1 pl-8 text-sm text-gray-600">{{ plus.organization }}</p>{% endif %}
            {% if plus.answers.size > 0 %}
              <dl class="mt-3 grid grid-cols-1 gap-2 pl-8 sm:grid-cols-2">
                {% for answer in plus.answers %}
                  <div>
                    <dt class="text-xs font-medium text-gray-500">{{ answer.label }}</dt>
                    <dd class="mt-0.5 text-sm text-gray-800">{{ answer.value }}</dd>
                  </div>
                {% endfor %}
              </dl>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.notes" | t }}</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in noteFields %}
        <div class="{{ field.span }}">
          {% render field.templateName, field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
    <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.ticket_codes" | t }}</h2>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      {% for field in ticketFields %}
        <div class="{{ field.span }}">
          {% render field.templateName, field: field %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if guestQrSvg != blank %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem" data-guest-qr-preview data-guest-qr-payload="{{ guestQrPayload }}">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.qr_code" | t }}</h2>
        <a class="text-sm font-semibold text-indigo-600 hover:text-indigo-800" href="{{ qrHref }}">{{ "events.views.guest_form.open_full_qr_ticket" | t }}</a>
      </div>
      <style>.guest-form-qr-ticket svg{display:block;width:320px;max-width:100%;height:auto;margin:0 auto}</style>
      <div class="guest-form-qr-ticket mt-4 rounded-lg border border-gray-100 bg-white p-3 text-center" style="max-width:22rem">
        {{ guestQrSvg | raw }}
        <a class="mt-3 inline-block text-xs font-semibold text-indigo-600 hover:text-indigo-800" href="{{ guestQrPngSrc }}" download>{{ "events.views.guest_qr.download_png" | t }}</a>
      </div>
    </div>
  {% endif %}

  {% if hasAdminCustomFields %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4" style="max-width:48rem">
      <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.additional_information" | t }}</h2>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
        {% for field in adminCustomFields %}
          <div class="{% if field.type == 'textarea' or field.type == 'radio' %}md:col-span-2{% endif %}">
            {% render field.templateName, field: field %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  </fieldset>

</form>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:48rem">
  {% if moveLists.size > 0 %}
    <form method="post" action="{{ moveAction }}" class="flex flex-wrap items-center gap-1.5" style="margin-top:1rem">
      <label class="block" style="margin:0"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.guest_form.move_to_list" | t }}</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="target_mail_list">
        <option value="">{{ "events.views.guest_form.select_a_list" | t }}</option>
        {% for list in moveLists %}<option value="{{ list.id }}">{{ list.name }}</option>{% endfor %}</select></label><button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="submit" title="{{ "events.views.guest_form.move_guest" | t }}" aria-label="{{ "events.views.guest_form.move_guest" | t }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#user-group"></use></svg><span class="hidden lg:inline">{{ "events.views.guest_form.move_guest" | t }}</span></button></form>{% endif %}
  {% if deleteAction != blank %}<form id="guest-delete-form" method="post" action="{{ deleteAction }}" data-confirm="{{ "events.views.guest_form.delete_this_guest" | t }}"></form>{% endif %}
  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    {% unless readOnly %}<button form="guest-form" type="submit" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">{{ "events.views.guest_form.save_guest" | t }}</button>{% endunless %}
    <a href="{{ listHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{% if readOnly %}{{ "events.views.guest_form.back" | t }}{% else %}{{ "events.views.guest_form.cancel" | t }}{% endif %}</a>
    {% if qrHref != blank %}<a href="{{ qrHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.guest_form.qr_code" | t }}</a>{% endif %}
    {% if deleteAction != blank %}<button form="guest-delete-form" type="submit" class="w-full px-6 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition-colors shadow-sm sm:ml-auto sm:w-auto">{{ "events.views.guest_form.delete" | t }}</button>{% endif %}
  </div>
</div>

{% if existingGuest %}
{% if hasResponseCustomSections %}
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-4" style="max-width:48rem">
  <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.activity_response" | t }}</h2>
  <div class="mt-4 space-y-6">
    {% for response in responseCustomSections %}
      <div data-response-submission data-response-ref="{{ response.responseRef }}"{% unless forloop.first %} class="border-t border-gray-200 pt-6"{% endunless %}>
        <div data-response-heading class="flex flex-wrap items-center justify-between gap-3">
          <div>
            {% if response.previewHref != blank %}
              <a href="{{ response.previewHref }}" target="_blank" rel="noopener" class="font-semibold text-indigo-600 underline decoration-indigo-200 underline-offset-2 hover:text-indigo-800">{{ response.name }}</a>
            {% else %}
              <div class="font-semibold text-gray-900">{{ response.name }}</div>
            {% endif %}
            <div class="mt-1 text-xs text-gray-500">
              {% if response.submittedAt != blank %}{{ response.submittedAt | date: "%Y-%m-%d %H:%M" | default: response.submittedAt }}{% else %}{{ "events.views.guest_form.no_date" | t }}{% endif %}
              {% if forloop.first and forloop.length > 1 %} · {{ "events.views.guest_form.latest_submission" | t }}{% endif %}
            </div>
          </div>
          {% if response.showRefill %}
            <label class="inline-flex items-center gap-2 text-sm text-gray-700" data-refill-scope="{{ response.refillScope }}">
              {%- comment -%} Empty twin: an unticked checkbox posts nothing, and a missing row would keep the stored one. {%- endcomment -%}
              <input type="hidden" name="{{ response.refillField }}" value="" form="guest-form">
              <input type="checkbox" name="{{ response.refillField }}" value="{{ response.refillScope }}" form="guest-form"{% if response.refillOpen %} checked{% endif %}{% if readOnly %} disabled{% endif %} style="accent-color:#4f46e5">
              <span class="font-medium">{{ "events.views.guest_form.reopen_response" | t }}</span>
            </label>
          {% endif %}
        </div>
        {% if response.hasFields %}
          <h3 class="mt-4 border-b border-gray-200 pb-2 text-sm font-bold text-indigo-700">{{ "events.views.guest_form.custom_information" | t }}</h3>
          <div class="divide-y divide-gray-100">
            {% for field in response.fields %}
              <div class="py-3">
                <div class="text-sm font-medium text-gray-700">{{ field.label }}:</div>
                <div class="mt-1 text-sm text-gray-900">{{ field.value }}</div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  <p class="mt-6 border-t border-gray-200 pt-4 text-xs text-gray-500">{{ "events.views.guest_form.refill_hint" | t }}</p>
</div>
{% endif %}
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-4" style="max-width:48rem">
  <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_form.activity" | t }}</h2>
  {% if hasActivity %}
    <div class="mt-4 divide-y divide-gray-100">
      {% for item in activity %}
        <div class="grid grid-cols-1 sm:grid-cols-[10rem_1fr] gap-2 py-3">
          <div class="text-xs text-gray-500 sm:text-right">
            {% if item.date != blank %}{{ item.date | date: "%Y-%m-%d %H:%M" | default: item.date }}{% else %}{{ "events.views.guest_form.no_date" | t }}{% endif %}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-block rounded px-2 py-0.5 text-xs font-semibold {% if item.kind == 'edm' %}bg-blue-50 text-blue-700{% elsif item.kind == 'checkin' %}bg-green-50 text-green-700{% else %}bg-gray-100 text-gray-700{% endif %}">{% if item.labelKey != blank %}{{ item.labelKey | t }}{% else %}{{ item.label }}{% endif %}</span>
              {% if item.status != blank %}<span class="text-sm font-semibold text-gray-900">{{ item.status | capitalize }}</span>{% endif %}
            </div>
            {% if item.message != blank %}<div class="mt-1 text-xs text-gray-500">{{ item.message }}</div>{% endif %}
            {% if item.hasResponseFields %}
              <details class="mt-3 rounded-lg border border-gray-200 bg-gray-50" data-activity-response-details data-response-edm-id="{{ item.responseEdmId }}">
                <summary class="cursor-pointer p-3 text-sm font-semibold text-gray-900">
                  {{ item.responseName }}
                  <span class="ml-2 text-xs font-bold text-indigo-700">{{ "events.views.guest_form.custom_information" | t }}</span>
                </summary>
                <div class="divide-y divide-gray-200 border-t border-gray-200 px-3 pb-1">
                  {% for field in item.responseFields %}
                    <div class="py-2">
                      <div class="text-xs font-medium text-gray-600">{{ field.label }}:</div>
                      <div class="mt-0.5 text-sm text-gray-900">{{ field.value }}</div>
                    </div>
                  {% endfor %}
                </div>
              </details>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="mt-3 text-sm text-gray-500">{{ "events.views.guest_form.no_activity_yet" | t }}</p>
  {% endif %}
</div>
{% endif %}
