<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref | escape }}">← {{ listName | escape }}</a><h1 class="text-2xl font-bold text-gray-900">{{ title | escape }}</h1><p class="mt-1 text-sm text-gray-500">{{ eventName | escape }}</p></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:48rem">
  <form method="post" action="{{ action | escape }}">
    {% if nativePageAction %}
      <input type="hidden" name="page_type" value="guest">
      <input type="hidden" name="slug" value="{{ slug | escape }}">
      <input type="hidden" name="weight" value="{{ weight }}">
      <input type="hidden" name="page_id" value="{{ pageId }}">
      <input type="hidden" name="*mail_list" value="{{ pageId }}">
      {% if eventId %}<input type="hidden" name="*event" value="{{ eventId }}">{% endif %}
    {% endif %}
    {% if returnTo %}<input type="hidden" name="return_to" value="{{ returnTo | escape }}">{% endif %}
    <div class="flex flex-wrap gap-3">
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">First name / display name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required value="{{ guest.name | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Last name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name=".last_name|{{ language | escape }}" value="{{ guest.last_name | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Email</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@email" type="email" value="{{ guest.email | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Phone</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@phone" value="{{ guest.phone | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Organisation</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@organization" value="{{ guest.organization | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Job title</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@job_title" value="{{ guest.job_title | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Plus guests</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@plus_guests" type="number" min="0" value="{{ guest.plus_guests | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Status</span><select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@status">{% for status in statuses %}<option value="{{ status.value | escape }}"{% if status.selected %} selected{% endif %}>{{ status.value | escape }}</option>{% endfor %}</select></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Preferred language</span><select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@prefer_language"><option value="">Not set</option><option value="en"{% if guest.prefer_language == 'en' %} selected{% endif %}>English</option><option value="zh-hant"{% if guest.prefer_language == 'zh-hant' %} selected{% endif %}>繁體中文</option><option value="zh-hans"{% if guest.prefer_language == 'zh-hans' %} selected{% endif %}>简体中文</option></select></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">CC email</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@cc" value="{{ guest.cc | escape }}"></label>
    </div>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Remarks</span><textarea class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="@remarks" rows="4">{{ guest.remarks | escape }}</textarea></label>
    {% if hasAdminCustomFields %}
      <div class="mt-6 pt-5 border-t border-gray-200">
        <h2 class="text-lg font-bold text-gray-900">Additional information</h2>
        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          {% for field in adminCustomFields %}
            <div class="{% if field.type == 'textarea' or field.type == 'radio' %}md:col-span-2{% endif %}">
              {% if field.type == 'checkbox' %}
                <label class="flex items-center gap-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300" type="checkbox" name="{{ field.name | escape }}" value="{{ field.defaultValue | default: 'yes' | escape }}"{% if field.checked %} checked{% endif %}{% if field.required %} required{% endif %}>
                  <span>{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
                </label>
              {% elsif field.type == 'select' %}
                <label class="block"><span class="block text-sm text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span><select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="{{ field.name | escape }}"{% if field.required %} required{% endif %}><option value=""></option>{% for option in field.options %}<option value="{{ option.value | escape }}"{% if option.selected %} selected{% endif %}>{{ option.label | escape }}</option>{% endfor %}</select></label>
              {% elsif field.type == 'radio' %}
                <fieldset class="block"><legend class="block text-sm text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</legend><div class="flex flex-wrap gap-3">{% for option in field.options %}<label class="inline-flex items-center gap-2 text-sm text-gray-700"><input type="radio" name="{{ field.name | escape }}" value="{{ option.value | escape }}"{% if option.selected %} checked{% endif %}{% if field.required %} required{% endif %}>{{ option.label | escape }}</label>{% endfor %}</div></fieldset>
              {% elsif field.type == 'textarea' %}
                <label class="block"><span class="block text-sm text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span><textarea class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="{{ field.name | escape }}" rows="3"{% if field.required %} required{% endif %}>{{ field.value | escape }}</textarea></label>
              {% else %}
                <label class="block"><span class="block text-sm text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="{{ field.type | escape }}" name="{{ field.name | escape }}" value="{{ field.value | escape }}"{% if field.required %} required{% endif %}></label>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    <div class="flex flex-wrap gap-2"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Save guest</button>{% if qrHref %}<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ qrHref | escape }}">QR code</a>{% endif %}</div>
  </form>
  {% if updateFromContactAction %}<form method="post" action="{{ updateFromContactAction | escape }}" style="margin-top:1rem" onsubmit="return confirm('Overwrite this guest with its linked contact record?')"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer" type="submit">Update from contact</button></form>{% endif %}
  {% if moveLists.size > 0 %}
    <form method="post" action="{{ moveAction | escape }}" class="flex flex-wrap items-center gap-1.5" style="margin-top:1rem">
      <label class="block" style="margin:0"><span class="block text-sm text-gray-700 mb-1">Move to list</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="target_mail_list">
        <option value="">Select a list</option>
        {% for list in moveLists %}<option value="{{ list.id }}">{{ list.name | escape }}</option>{% endfor %}</select></label><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer" type="submit">Move guest</button></form>{% endif %}
  {% if deleteAction %}<form method="post" action="{{ deleteAction | escape }}" style="margin-top:1rem" onsubmit="return confirm('Delete this guest?')"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-red-600 text-white hover:bg-red-700 cursor-pointer" type="submit">Delete guest</button></form>{% endif %}
</div>

{% if deleteAction %}
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-4" style="max-width:48rem">
  <h2 class="text-lg font-bold text-gray-900">Activity</h2>
  {% if hasActivity %}
    <div class="mt-4 divide-y divide-gray-100">
      {% for item in activity %}
        <div class="grid grid-cols-1 sm:grid-cols-[10rem_1fr] gap-2 py-3">
          <div class="text-xs text-gray-500 sm:text-right">
            {% if item.date != blank %}{{ item.date | date: "%Y-%m-%d %H:%M" | default: item.date }}{% else %}No date{% endif %}
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-block rounded px-2 py-0.5 text-xs font-semibold {% if item.kind == 'edm' %}bg-blue-50 text-blue-700{% elsif item.kind == 'checkin' %}bg-green-50 text-green-700{% else %}bg-gray-100 text-gray-700{% endif %}">{{ item.label | escape }}</span>
              {% if item.status != blank %}<span class="text-sm font-semibold text-gray-900">{{ item.status | capitalize | escape }}</span>{% endif %}
            </div>
            {% if item.message != blank %}<div class="mt-1 text-xs text-gray-500">{{ item.message | escape }}</div>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="mt-3 text-sm text-gray-500">No activity yet.</p>
  {% endif %}
</div>
{% endif %}
