<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref }}">← {{ listName }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ guestName }}</h1>
    {% if organization %}<p class="mt-1 text-sm text-gray-500">{{ organization }}</p>{% endif %}
  </div>
  <div class="flex flex-wrap items-center gap-2">
    {% if checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700">{{ "events.views.guest_qr.main_guest_checked_in" | t }}</span>{% endif %}
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ attendanceLabel }}</span>
    {% if editHref != blank %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50" title="{{ "events.views.guest_qr.edit_guest" | t }}" aria-label="{{ "events.views.guest_qr.edit_guest" | t }}" href="{{ editHref }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#pencil-square"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_qr.edit_guest" | t }}</span>
    </a>{% endif %}
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="button" onclick="window.print()" title="{{ "events.views.guest_qr.print" | t }}" aria-label="{{ "events.views.guest_qr.print" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#document"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_qr.print" | t }}</span>
    </button>
  </div>
</div>
<style>.guest-qr-ticket svg{display:block;width:320px;max-width:100%;height:auto;margin:0 auto}</style>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center guest-qr-ticket" style="max-width:22rem">
  {{ qrSvg | raw }}
  <a class="mt-3 inline-block text-xs font-semibold text-indigo-600 hover:text-indigo-800" href="{{ qrPngSrc }}" download>{{ "events.views.guest_qr.download_png" | t }}</a>
</div>
{% if pairAction != blank %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4" style="max-width:32rem">
  <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_qr.badge_pairing" | t }}</h2>
  <form method="post" action="{{ pairAction }}" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
    <label class="block flex-1" style="margin:0">
      <span class="block text-sm text-gray-700 mb-1">{{ "events.views.guest_qr.paired_badge_qr_code" | t }}</span>
      <input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="text" name="paired_qrcode" value="{{ pairedQrCode }}" autocomplete="off" autofocus>
    </label>
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit" title="{{ "events.views.guest_qr.pair_badge_qr_code" | t }}" aria-label="{{ "events.views.guest_qr.pair_badge_qr_code" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#document"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_qr.pair_badge" | t }}</span>
    </button>
  </form>
</div>
{% endif %}
{% if hasPlusGuestQrs %}
<div class="mt-6">
  <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_qr.plus_guest_qr_codes" | t }}</h2>
  <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for plus in plusGuestQrs %}
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <h3 class="text-sm font-semibold text-gray-900">{{ plus.label }}</h3>
        {% if plus.organization != blank %}<p class="mt-1 text-xs text-gray-500">{{ plus.organization }}</p>{% endif %}
        <div class="guest-qr-ticket" style="margin-top:0.75rem">{{ plus.qrSvg | raw }}</div>
        <p class="text-xs text-gray-500" style="margin-top:0.75rem;word-break:break-all">{{ plus.payload }}</p>
        <div class="mt-3 flex items-center justify-center gap-3 text-xs font-semibold">
          <a class="text-indigo-600 hover:text-indigo-800" href="{{ plus.pngSrc }}" target="_blank" rel="noopener">{{ "events.views.guest_qr.view_png" | t }}</a>
          <a class="text-indigo-600 hover:text-indigo-800" href="{{ plus.pngSrc }}" download="{{ plus.filename }}">{{ "events.views.guest_qr.download_png" | t }}</a>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}
{% if hasLinkedCompanionQrs %}
<div class="mt-6" style="max-width:42rem">
  <h2 class="text-lg font-bold text-gray-900">{{ "events.views.guest_qr.named_companion_qr_codes" | t }}</h2>
  <div class="mt-3 divide-y divide-gray-100 rounded-xl border border-gray-200 bg-white px-4">
    {% for companion in linkedCompanionQrs %}
      <div class="flex flex-wrap items-center justify-between gap-3 py-3">
        <div><p class="text-sm font-semibold text-gray-900">{{ companion.name }}</p>{% if companion.organization != blank %}<p class="text-xs text-gray-500">{{ companion.organization }}</p>{% endif %}</div>
        <a class="text-sm font-semibold text-indigo-600 hover:text-indigo-800" href="{{ companion.qrHref }}">{{ "events.views.guest_qr.open_individual_qr_ticket" | t }}</a>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}
