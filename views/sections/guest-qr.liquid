<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref | escape }}">← {{ listName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ guestName | escape }}</h1>
    {% if organization %}<p class="mt-1 text-sm text-gray-500">{{ organization | escape }}</p>{% endif %}
  </div>
  <div class="flex flex-wrap items-center gap-2">
    {% if checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Checked in</span>{% endif %}
    {% if editHref != blank %}<a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50" title="Edit guest" aria-label="Edit guest" href="{{ editHref | escape }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#pencil-square"></use></svg>
      <span class="hidden lg:inline">Edit guest</span>
    </a>{% endif %}
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer" type="button" onclick="window.print()" title="Print" aria-label="Print">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#document"></use></svg>
      <span class="hidden lg:inline">Print</span>
    </button>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center" style="max-width:22rem">
  <div style="width:240px;height:240px;margin:0 auto">{{ qrSvg }}</div>
  <p class="text-sm text-gray-500" style="margin-top:1rem;word-break:break-all">{{ payload | escape }}</p>
</div>
{% if pairAction != blank %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4" style="max-width:32rem">
  <h2 class="text-lg font-bold text-gray-900">Badge pairing</h2>
  <form method="post" action="{{ pairAction | escape }}" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
    <label class="block flex-1" style="margin:0">
      <span class="block text-sm text-gray-700 mb-1">Paired badge QR code</span>
      <input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="text" name="paired_qrcode" value="{{ pairedQrCode | escape }}" autocomplete="off" autofocus>
    </label>
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit" title="Pair badge QR code" aria-label="Pair badge QR code">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#document"></use></svg>
      <span class="hidden lg:inline">Pair badge</span>
    </button>
  </form>
</div>
{% endif %}
{% if hasPlusGuestQrs %}
<div class="mt-6">
  <h2 class="text-lg font-bold text-gray-900">Plus guest QR codes</h2>
  <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for plus in plusGuestQrs %}
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 text-center">
        <h3 class="text-sm font-semibold text-gray-900">{{ plus.label | escape }}</h3>
        <div style="width:180px;height:180px;margin:0.75rem auto 0">{{ plus.qrSvg }}</div>
        <p class="text-xs text-gray-500" style="margin-top:0.75rem;word-break:break-all">{{ plus.payload | escape }}</p>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}
