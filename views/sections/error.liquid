<div class="flex items-center justify-between gap-4 mb-4"><h1 class="text-2xl font-bold text-gray-900">{{ heading | default: 'Cannot reach the CMS' }}</h1></div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
  <p class="text-sm text-gray-500">{{ message }}</p>
  {% if showConfig %}
  <p class="text-sm text-gray-500" style="margin-top:.75rem">{{ "events.views.error.set" | t }} <code class="bg-gray-100 px-1 py-0.5 rounded text-xs font-mono">CMS_URL</code> {{ "events.views.error.and" | t }} <code class="bg-gray-100 px-1 py-0.5 rounded text-xs font-mono">PLUGIN_SECRET</code> {{ "events.views.error.on_this_plugin_worker" | t }}
  {{ "events.views.error.secret_note" | t }}</p>
  {% endif %}
</div>
