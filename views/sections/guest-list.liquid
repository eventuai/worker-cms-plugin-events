<div class="ev-head">
  <div>
    <a class="ev-back" href="{{ listsHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="ev-h1">{{ listName | escape }}</h1>
    <p class="ev-sub">{{ total }} guest{% if total != 1 %}s{% endif %}</p>
  </div>
  <div class="ev-actions">
    <a class="ev-btn ev-btn-primary" href="{{ newGuestHref | escape }}">New guest</a>
    <a class="ev-btn ev-btn-secondary" href="{{ importHref | escape }}">Import CSV</a>
    <a class="ev-btn ev-btn-secondary" href="{{ exportHref | escape }}">Export CSV</a>
    <form method="post" action="{{ updateFromContactsAction | escape }}" onsubmit="return confirm('Refresh every linked guest from its contact record?')"><button class="ev-btn ev-btn-secondary" type="submit">Update from contacts</button></form>
    <form method="post" action="{{ deleteAction | escape }}" onsubmit="return confirm('Delete this guest list and its guests?')"><button class="ev-btn ev-btn-danger" type="submit">Delete list</button></form>
  </div>
</div>
<div class="ev-card ev-card-pad" style="margin-bottom:1rem">
  <form class="ev-search" method="get" action="{{ listHref | escape }}">
    <input class="ev-input" style="max-width:22rem" name="q" value="{{ q | escape }}" placeholder="Search name or slug">
    <select class="ev-input" style="width:auto" name="status">
      <option value="">All statuses</option>
      {% for status in statuses %}<option value="{{ status | escape }}"{% if status == selectedStatus %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
    </select>
    <button class="ev-btn ev-btn-secondary" type="submit">Filter</button>
  </form>
</div>
<div class="ev-card">
  <table class="ev-table">
    <thead><tr><th>Name</th><th>Email</th><th>Organisation</th><th>Status</th><th>Check-in</th><th></th></tr></thead>
    <tbody>
      {% for guest in guests %}
        <tr>
          <td><a href="{{ guest.editHref | escape }}">{{ guest.name | escape }}</a></td>
          <td>{{ guest.email | escape }}</td>
          <td>{{ guest.organization | escape }}</td>
          <td>
            <form method="post" action="{{ guest.statusAction | escape }}" class="ev-inline-form">
              <select class="ev-status" name="status">
                {% for status in statuses %}<option value="{{ status | escape }}"{% if status == guest.status %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
              </select><button class="ev-text-button" type="submit">Save</button>
            </form>
          </td>
          <td>{% if guest.checkedIn %}<span class="ev-badge">Checked in</span>{% else %}<form method="post" action="{{ guest.checkinAction | escape }}"><button class="ev-text-button" type="submit">Check in</button></form>{% endif %}</td>
          <td style="text-align:right"><a href="{{ guest.qrHref | escape }}">QR</a> · <a href="{{ guest.editHref | escape }}">Edit →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="6" class="ev-empty">No guests match this list.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
