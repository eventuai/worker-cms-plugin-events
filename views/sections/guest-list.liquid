<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listsHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ listName | escape }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ total }} guest{% if total != 1 %}s{% endif %}</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ newGuestHref | escape }}">New guest</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ importHref | escape }}">Import CSV</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ exportHref | escape }}">Export CSV</a>
    <a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ editHref | escape }}">Edit guest list ↗</a>
    <form method="post" action="{{ updateFromContactsAction | escape }}" data-confirm="Refresh every linked guest from its contact record?"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer" type="submit">Update from contacts</button></form>
    <form method="post" action="{{ deleteAction | escape }}" data-confirm="Delete this guest list and its guests?"><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-red-600 text-white hover:bg-red-700 cursor-pointer" type="submit">Delete list</button></form>
  </div>
</div>

{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash | escape }}</p>{% endif %}

{%- comment -%} ── Email campaign: link an EDM, then send / auto-send to guests ── {%- endcomment -%}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <form method="post" action="{{ setEdmAction | escape }}" class="flex flex-wrap items-center gap-2">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">Email template (EDM)</span>
        {%- comment -%} data-autosubmit: the CMS layout submits this form on change (CSP-safe). {%- endcomment -%}
        <select name="edm_id" data-autosubmit class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" style="min-width:16rem">
          <option value="">— No EDM —</option>
          {% for edm in edmOptions %}<option value="{{ edm.id }}"{% if edm.selected %} selected{% endif %}>{{ edm.name | escape }}</option>{% endfor %}
        </select>
      </label>
      <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Set</button>
      {% unless hasEdmOptions %}<span class="text-xs text-gray-400 py-2">No EDMs for this event yet.</span>{% endunless %}
    </form>

    {% if hasEdm %}
      <div class="flex flex-wrap items-center gap-2">
        <a class="inline-block px-3 py-2 rounded-lg text-sm font-semibold text-indigo-600 hover:text-indigo-800" href="{{ edmEditHref | escape }}">Edit “{{ edmName | escape }}” ↗</a>
        <form method="post" action="{{ autoSendGoodAction | escape }}" data-confirm="Send this EDM to all good-quality guests not sent yet?">
          <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold bg-green-600 text-white hover:bg-green-700 cursor-pointer">▶ Auto Send (Good)</button>
        </form>
        <form method="post" action="{{ autoSendRiskyAction | escape }}" data-confirm="Send this EDM to all risky-quality guests not sent yet?">
          <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold bg-amber-50 text-amber-700 border border-amber-300 hover:bg-gray-50 cursor-pointer">▶ Auto Send (Risky)</button>
        </form>
      </div>
    {% endif %}
  </div>
  {% if hasEdm %}<p class="mt-4 text-xs text-gray-400">Auto-send skips paused guests and anyone already sent this EDM. “Good” vs “Risky” is a deliverability heuristic on the address; re-send individually below.</p>{% endif %}
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
  <form class="flex flex-wrap items-center gap-3" method="get" action="{{ listHref | escape }}">
    <input class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" style="max-width:22rem" name="q" value="{{ q | escape }}" placeholder="Search name or slug">
    <select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="status">
      <option value="">All statuses</option>
      {% for status in statuses %}<option value="{{ status | escape }}"{% if status == selectedStatus %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
    </select>
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" type="submit">Filter</button>
  </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name / Email</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organisation</th>
      {% if hasEdm %}<th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email&nbsp;send</th>{% endif %}
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Check-in</th>
      <th class="px-6 py-3"></th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">
            <a class="block text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">{{ guest.name | escape }}</a>
            <div class="text-gray-500 text-sm">
            {{ guest.email | escape }}
            {% if hasEdm %}
              {% if guest.isGood %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700">good</span>
              {% elsif guest.isRisky %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">risky</span>
              {% else %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">no email</span>{% endif %}
            {% endif %}
            </div>            
          </td>
          <td class="px-6 py-3 text-sm text-gray-700">
            {{ guest.organization | escape }}
            {% if guest.job_title %}
              <div class="text-gray-500 text-sm">{{ guest.job_title | escape }}</div>
            {% endif %}
          </td>
          {% if hasEdm %}
            <td class="px-6 py-3 text-sm text-gray-700">
              {% if guest.canEmail %}
                {% if guest.notSend %}
                  <span class="text-xs text-gray-400">Paused</span>
                {% else %}
                  <span class="inline-flex items-center gap-2">
                    <form method="post" action="{{ guest.sendAction | escape }}" class="inline-block">
                      {% if guest.sent %}
                        <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Re-send</button>
                      {% elsif guest.isGood %}
                        <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold bg-green-600 text-white hover:bg-green-700 cursor-pointer">Send</button>
                      {% else %}
                        <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-300 hover:bg-gray-50 cursor-pointer">Send</button>
                      {% endif %}
                    </form>
                    <a class="text-xs font-semibold text-indigo-600 hover:text-indigo-800" href="{{ guest.previewHref | escape }}" target="_blank" rel="noopener">Preview</a>
                  </span>
                {% endif %}
              {% else %}
                <span class="text-xs text-gray-400">No email</span>
              {% endif %}
            </td>
          {% endif %}
          <td class="px-6 py-3 text-sm text-gray-700">
            <form method="post" action="{{ guest.statusAction | escape }}" class="flex flex-wrap items-center gap-1.5">
              <select class="border border-gray-300 rounded-md p-1 text-xs bg-white max-w-[9rem]" name="status">
                {% for status in statuses %}<option value="{{ status | escape }}"{% if status == guest.status %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
              </select><button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer" type="submit">Save</button>
            </form>
          </td>
          <td class="px-6 py-3 text-sm text-gray-700">{% if guest.checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Checked in</span>{% else %}<form method="post" action="{{ guest.checkinAction | escape }}"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer" type="submit">Check in</button></form>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.qrHref | escape }}">QR</a> · <a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">Edit →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="{% if hasEdm %}7{% else %}6{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">No guests match this list.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
