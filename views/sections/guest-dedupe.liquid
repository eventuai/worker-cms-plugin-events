<div class="mb-4">
  <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref }}">{{ "events.views.guest_dedupe.back_to_guest_list" | t }}</a>
  <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.guest_dedupe.remove_duplicates" | t }}</h1>
  <p class="mt-1 text-sm text-gray-500">{{ listName }} · {{ eventName }}</p>
</div>

<div class="flex flex-wrap gap-2 mb-4">
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ guestCount }} guests</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ duplicateCount }} identical copies in {{ groupCount }} group(s)</span>
</div>

{% if duplicateCount == 0 %}
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <p class="text-sm text-gray-600">{{ "events.views.guest_dedupe.no_identical_copies_found_every_guest_differs_from_the_others_in_at_leas" | t }}</p>
  </div>
{% else %}
  <p class="text-sm text-gray-600 mb-4">{{ "events.views.guest_dedupe.only_rows_that_match_another_guest_on_the_name_and_every_field_group_as_" | t }}</p>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mb-4">
    <table class="w-full min-w-[560px] text-left relative" data-privacy-table>
      <thead class="bg-gray-50 border-b border-gray-200"><tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_dedupe.name" | t }}</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_dedupe.email" | t }}</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_dedupe.copies" | t }}</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "events.views.guest_dedupe.removing" | t }}</th>
      </tr></thead>
      <tbody class="divide-y divide-gray-100">
        {% for group in groups %}
          <tr>
            <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="name">{{ group.name }}</span></td>
            <td class="px-6 py-3 text-sm text-gray-700"><span data-private-field="email">{{ group.email }}</span></td>
            <td class="px-6 py-3 text-sm text-gray-600">{{ group.copies }}</td>
            <td class="px-6 py-3 text-sm text-amber-700">{{ group.removing }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if moreGroups > 0 %}
    <p class="text-sm text-gray-500 mb-4">…and {{ moreGroups }} more group(s).</p>
  {% endif %}

  <form method="post" action="{{ action }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="{{ "events.views.guest_dedupe.remove_duplicates" | t }}" aria-label="{{ "events.views.guest_dedupe.remove_duplicates" | t }}">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg>
        <span class="hidden lg:inline">Remove {{ duplicateCount }} duplicate(s)</span>
      </button>
      <a href="{{ listHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.guest_dedupe.cancel" | t }}</a>
    </div>
  </form>
{% endif %}
