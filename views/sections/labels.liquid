<div class="flex items-center justify-between gap-4 mb-4"><div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventHref }}">← {{ eventName }}</a><h1 class="text-2xl font-bold text-gray-900">Label templates</h1><p class="mt-1 text-sm text-gray-500">Design printable name badges. Open a label to edit it in the label editor.</p></div><a class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700" title="New label" aria-label="New label" href="{{ newHref }}"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg><span class="hidden lg:inline">New label</span></a></div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto"><table class="w-full min-w-[560px] text-left relative" data-reorder="{{ reorderAction }}" data-reorder-key="updates" data-reorder-mode="weight" data-reorder-handle-only><thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-4 py-3 w-10"></th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Size</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th><th class="px-6 py-3"></th></tr></thead><tbody class="divide-y divide-gray-100">
  {% for label in labels %}<tr data-id="{{ label.id }}"><td class="px-4 py-3 text-gray-400" data-reorder-handle title="Drag to reorder" style="cursor:grab"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" d="M9 5h.01M9 12h.01M9 19h.01M15 5h.01M15 12h.01M15 19h.01" /></svg></td><td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ label.href }}">{{ label.name }}</a></td><td class="px-6 py-3 text-sm text-gray-700">{{ label.size }}</td><td class="px-6 py-3 text-sm">{% if label.isPublished %}<span class="inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-xs font-semibold text-green-700">Published</span>{% else %}<span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-600">Draft</span>{% endif %}</td><td class="px-6 py-3 text-right whitespace-nowrap"><div class="inline-flex items-center gap-2"><a href="{{ label.href }}" title="Edit label template" aria-label="Edit {{ label.name }}" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#pencil-square"></use></svg><span class="sr-only">Edit</span></a>{% if label.isPublished %}<form method="post" action="{{ label.unpublishAction }}" class="inline shrink-0" data-confirm="Unpublish this label template?"><button type="submit" title="Unpublish label template" aria-label="Unpublish {{ label.name }}" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-yellow-600 hover:bg-yellow-50 hover:text-yellow-800 cursor-pointer"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#eye-off"></use></svg><span class="sr-only">Unpublish</span></button></form>{% else %}<form method="post" action="{{ label.publishAction }}" class="inline shrink-0"><button type="submit" title="Publish label template" aria-label="Publish {{ label.name }}" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-green-600 hover:bg-green-50 hover:text-green-800 cursor-pointer"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#cloud-upload"></use></svg><span class="sr-only">Publish</span></button></form>{% endif %}<form method="post" action="{{ label.deleteAction }}" class="inline shrink-0" data-confirm="Delete label template “{{ label.name }}”?"><button type="submit" title="Delete label template" aria-label="Delete {{ label.name }}" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-600 hover:bg-red-50 hover:text-red-700 cursor-pointer"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg><span class="sr-only">Delete</span></button></form></div></td></tr>
  {% else %}<tr><td colspan="5" class="px-6 py-10 text-center text-sm text-gray-400">No label templates yet.</td></tr>{% endfor %}
</tbody></table></div>
