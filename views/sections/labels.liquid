<div class="flex items-center justify-between gap-4 mb-4"><div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ eventHref | escape }}">← {{ eventName | escape }}</a><h1 class="text-2xl font-bold text-gray-900">Label templates</h1><p class="mt-1 text-sm text-gray-500">Create SVG name badges and print their preview from the browser.</p></div><a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700" href="{{ newHref | escape }}">New label</a></div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Size</th><th class="px-6 py-3"></th></tr></thead><tbody class="divide-y divide-gray-100">
  {% for label in labels %}<tr><td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ label.href | escape }}">{{ label.name | escape }}</a></td><td class="px-6 py-3 text-sm text-gray-700">{{ label.width | escape }} × {{ label.height | escape }}</td><td class="px-6 py-3 text-right"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ label.previewHref | escape }}" target="_blank">Preview / print ↗</a></td></tr>
  {% else %}<tr><td colspan="3" class="px-6 py-10 text-center text-sm text-gray-400">No label templates yet.</td></tr>{% endfor %}
</tbody></table></div>
