<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ importHref | escape }}">← Choose a different file</a>
    <h1 class="text-2xl font-bold text-gray-900">Preview import</h1>
    <p class="mt-1 text-sm text-gray-500">{{ eventName | escape }}</p>
  </div>
</div>

<div class="flex flex-wrap gap-2 mb-4">
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ total }} rows</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700">{{ newListCount }} new lists</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">{{ newCount }} new guests</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">{{ updateCount }} to update</span>
  <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">{{ unchangedCount }} no change</span>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto mb-4">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest list</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">List</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Rows</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">New</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Updates</th>
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">No change</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for group in groups %}
        <tr>
          <td class="px-6 py-3 text-sm font-medium text-gray-800">{{ group.listName | escape }}</td>
          <td class="px-6 py-3 text-sm">
            {% if group.listState == 'new' %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700">Will create</span>
            {% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Existing</span>{% endif %}
          </td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ group.total }}</td>
          <td class="px-6 py-3 text-sm text-green-700">{{ group.newCount }}</td>
          <td class="px-6 py-3 text-sm text-amber-700">{{ group.updateCount }}</td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ group.unchangedCount }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<form method="post" action="{{ confirmAction | escape }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" data-long-running-form>
  <textarea name="csv" style="display:none">{{ csv | escape }}</textarea>
  <label class="block mb-4" style="max-width:30rem">
    <span class="block text-sm font-medium text-gray-700 mb-1">How should these be imported?</span>
    <select name="mode" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="new_and_update">Import new guests and update existing guests</option>
      <option value="new_only">Import new guests only</option>
      <option value="update_only">Update existing guests only</option>
    </select>
  </label>
  <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" title="Confirm import" aria-label="Confirm import" data-loading-label="Importing guests">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
      <span class="hidden lg:inline">Confirm import</span>
    </button>
    <a href="{{ backHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
  </div>
</form>
<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
