{%- assign cls_input = "block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" -%}
{%- assign cls_label = "block text-sm font-medium text-gray-700 mb-1" -%}

<div class="flex items-center justify-between gap-4 mb-4" style="max-width:48rem">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">&larr; Events</a>
    <h1 class="text-2xl font-bold text-gray-900">New event</h1>
  </div>
</div>

{% if errors and errors != empty %}
  <ul class="mb-4 rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-red-600" style="max-width:48rem">
    {% for error in errors %}<li>{{ error | escape }}</li>{% endfor %}
  </ul>
{% endif %}
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700" style="max-width:48rem">{{ flash | escape }}</p>{% endif %}

<form id="event-form" method="post" action="{{ action | escape }}" data-editor-form class="space-y-4" style="max-width:48rem">
  <input type="hidden" name="page_type" value="event">
  <input type="hidden" name="weight" value="{{ weight }}">
  <input type="hidden" name="return_to" value="{{ backHref | escape }}">
  <input type="hidden" name="@type" value="event">

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
      <label class="block">
        <input id="event-name" class="{{ cls_input }}" name="name" value="{{ name | escape }}" required autocomplete="off" placeholder="Event name *">
        <div class="text-gray-500 font-mono text-xs mt-1">/<input id="event-slug" class="font-mono text-xs border-0" name="slug" value="{{ slug | escape }}" required autocomplete="off" placeholder="slug"></div>
      </label>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <label class="flex items-center gap-2">
        <span class="{{ cls_label }}">From</span>
        <input class="{{ cls_input }}" name="start" type="datetime-local" value="{{ start | escape }}">
      </label>
      <label class="flex items-center gap-2">
        <span class="{{ cls_label }}">Until</span>
        <input class="{{ cls_input }}" name="end" type="datetime-local" value="{{ end | escape }}">
      </label>
      <label class="flex items-center gap-2">
        <select class="{{ cls_input }}" name="timezone">
          {% for option in timezoneOptions %}
            <option value="{{ option.value | escape }}"{% if option.selected %} selected{% endif %}>{{ option.label | escape }}</option>
          {% endfor %}
        </select>
      </label>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-3">
    <h2 class="text-lg font-bold text-gray-900">Use case</h2>
    <div class="space-y-2">
      {% for option in useCases %}
        <label class="flex items-start gap-3 rounded-lg border border-gray-300 p-3 cursor-pointer hover:bg-gray-50">
          <input class="mt-1" type="radio" name="@event_use_case" value="{{ option.value | escape }}"{% if option.selected %} checked{% endif %}>
          <span class="text-sm font-semibold text-gray-900">{{ option.label | escape }}</span>
        </label>
      {% endfor %}
    </div>
  </div>

  <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit" name="action" value="update" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Create event</button>
    <a href="{{ backHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
  </div>
</form>

<script src="/admin/plugins/events/assets/event-new.js" defer></script>
