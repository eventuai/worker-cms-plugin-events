{%- assign cls_input = "block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" -%}
{%- assign cls_label = "block text-sm font-medium text-gray-700 mb-1" -%}

<div class="mb-3" style="max-width:48rem">
  <a class="inline-block text-xs text-gray-500 hover:text-indigo-700" href="{{ backHref }}">{{ "events.views.event_new.events" | t }}</a>
</div>

{% if errors and errors != empty %}
  <ul class="mb-4 rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-red-600" style="max-width:48rem">
    {% for error in errors %}<li>{{ error }}</li>{% endfor %}
  </ul>
{% endif %}
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700" style="max-width:48rem">{{ flash | t }}</p>{% endif %}

<form id="event-form" method="post" action="{{ action }}" data-editor-form class="space-y-4" style="max-width:48rem">
  <input type="hidden" name="page_type" value="event">
  <input type="hidden" name="weight" value="{{ weight }}">
  <input type="hidden" name="return_to" value="{{ backHref }}">
  <input type="hidden" name="@type" value="event">

  <!-- Event name doubles as the page title: click the "New event" heading to type the name. -->
  <div>
    <input id="event-name" class="block w-full border-0 p-0 bg-transparent text-2xl font-bold text-gray-900 focus:outline-none focus:ring-0" name="name" value="{{ name }}" required autocomplete="off" placeholder="{{ "events.views.event_new.new_event" | t }}">
    <div class="text-gray-500 font-mono text-xs mt-1 w-full flex">/<input id="event-slug" class="font-mono text-xs border-0 w-full focus:outline-none focus:ring-0" name="slug" value="{{ slug }}" required autocomplete="off" placeholder="{{ "events.views.event_new.slug" | t }}"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
  <label class="flex items-center gap-2">
    <span class="{{ cls_label }}">{{ "events.views.event_new.from" | t }}</span>
    <input class="{{ cls_input }}" name="start" type="datetime-local" value="{{ start }}">
  </label>
  <label class="flex items-center gap-2">
    <span class="{{ cls_label }}">{{ "events.views.event_new.until" | t }}</span>
    <input class="{{ cls_input }}" name="end" type="datetime-local" value="{{ end }}">
  </label>
  <label class="flex items-center gap-2">
    <select class="{{ cls_input }}" name="timezone">
      {% for option in timezoneOptions %}
        <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
      {% endfor %}
    </select>
  </label>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-3">
    <div class="space-y-2">
      {% for option in useCases %}
        <label class="flex items-start gap-3 rounded-lg border border-gray-300 p-3 cursor-pointer hover:bg-gray-50">
          <input class="mt-1" type="radio" name="@event_use_case" value="{{ option.value }}"{% if option.selected %} checked{% endif %}>
          <span class="min-w-0 flex-1 text-sm font-semibold text-gray-900">{{ option.label }}</span>
          {% if showCredits %}<span class="shrink-0 inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-600 whitespace-nowrap">{% if option.setupCredits > 0 %}{{ option.setupCredits }} credits{% else %}Free{% endif %}</span>{% endif %}
        </label>
      {% endfor %}
    </div>
    {% if showCredits %}<p class="text-xs text-gray-400">{{ "events.views.event_new.one_time_setup_cost_importing_guests_and_sending_emails_are_billed_separ" | t }}</p>{% endif %}
  </div>

  <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit" name="action" value="update" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">{{ "events.views.event_new.create_event" | t }}</button>
    <a href="{{ backHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.event_new.cancel" | t }}</a>
  </div>
</form>

<script src="/admin/plugins/events/assets/event-new.js" defer></script>
