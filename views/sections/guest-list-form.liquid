<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "events.views.guest_list_form.guest_lists" | t }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ title | default: "New guest list" }}</h1>
  </div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action }}">
    {% if selectedEventId %}
      <input type="hidden" name="event_id" value="{{ selectedEventId }}">
    {% else %}
      <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.guest_list_form.event" | t }}</span>
        <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="event_id" required>
          <option value="">{{ "events.views.guest_list_form.select_an_event" | t }}</option>
          {% for event in events %}
            <option value="{{ event.id }}"{% if event.selected %} selected{% endif %}>{{ event.name }}</option>
          {% endfor %}
        </select>
      </label>
    {% endif %}
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.guest_list_form.list_name" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required placeholder="{{ "events.views.guest_list_form.vip_guests" | t }}"></label>
    <input type="hidden" name="allow_checkin" value="yes">
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit" title="{{ "events.views.guest_list_form.create_guest_list" | t }}" aria-label="{{ "events.views.guest_list_form.create_guest_list" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_list_form.create_guest_list" | t }}</span>
    </button>
  </form>
</div>
