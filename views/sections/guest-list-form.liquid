<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Guest lists</a><h1 class="text-2xl font-bold text-gray-900">New guest list</h1></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action | escape }}">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Event</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="event_id" required>
        <option value="">Select an event</option>
        {% for event in events %}
          <option value="{{ event.id }}"{% if event.selected %} selected{% endif %}>{{ event.name | escape }}</option>
        {% endfor %}
      </select>
    </label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">List name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required placeholder="VIP guests"></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Check-in</span>
      <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="allow_checkin"><option value="yes">Enabled</option><option value="no">Disabled</option></select>
    </label>
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Create guest list</button>
  </form>
</div>
