<div class="flex items-center justify-between gap-4 mb-4"><div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Label templates</a><h1 class="text-2xl font-bold text-gray-900">{{ title | escape }}</h1><p class="mt-1 text-sm text-gray-500">{{ eventName | escape }}</p></div>{% if previewHref %}<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50" href="{{ previewHref | escape }}" target="_blank">Preview / print ↗</a>{% endif %}</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 max-w-4xl">
  <form method="post" action="{{ action | escape }}">
    <div class="flex flex-wrap gap-3">
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Template name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required value="{{ label.name | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Width</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="width" value="{{ label.width | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Height</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="height" value="{{ label.height | escape }}"></label>
      <label class="block mb-3 flex-1 min-w-[10rem]"><span class="block text-sm text-gray-700 mb-1">Direction</span><select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="direction"><option value="landscape"{% if label.direction == 'landscape' %} selected{% endif %}>Landscape</option><option value="portrait"{% if label.direction == 'portrait' %} selected{% endif %}>Portrait</option></select></label>
    </div>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">SVG template</span><textarea class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" name="svg" rows="16" required>{{ label.svg | escape }}</textarea></label>
    <p class="mt-1 text-sm text-gray-500" style="margin-bottom:1rem">Available guest placeholders: <code>{{name}}</code>, <code>{{organization}}</code>, <code>{{email}}</code>, <code>{{qr_code}}</code>.</p>
    <button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" type="submit">Save label template</button>
  </form>
</div>
{% if previewHref %}<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 max-w-4xl" style="margin-top:1rem"><h2 class="text-lg font-bold text-gray-900">Guest preview</h2><p class="mt-1 text-sm text-gray-500">Choose a guest, then open a printable SVG preview.</p><form method="get" action="{{ previewHref | escape }}" target="_blank" class="flex flex-wrap gap-2" style="margin-top:1rem"><select class="block px-3 py-2 border border-gray-300 rounded-lg text-sm" style="max-width:28rem" name="guest_id"><option value="">Example values</option>{% for guest in guests %}<option value="{{ guest.id }}">{{ guest.name | escape }}</option>{% endfor %}</select><button class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer" type="submit">Preview / print</button></form></div>{% endif %}
