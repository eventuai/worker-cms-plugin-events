<div class="flex items-center justify-between gap-4 mb-4"><div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "events.views.label_form.label_templates" | t }}</a><h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1><p class="mt-1 text-sm text-gray-500">{{ eventName }}</p></div></div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700" style="max-width:36rem">{{ flash }}</p>{% endif %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action }}" enctype="multipart/form-data">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.label_form.template_name" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required value="{{ label.name }}" placeholder="{{ "events.views.label_form.guest_badge_60_30" | t }}"></label>
    <div class="flex flex-wrap gap-3">
      <label class="block mb-3 flex-1"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.label_form.width_mm" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="number" min="10" max="210" name="width" value="{{ label.width }}"></label>
      <label class="block mb-3 flex-1"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.label_form.height_mm" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="number" min="10" max="210" name="height" value="{{ label.height }}"></label>
    </div>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.label_form.start_from_a_design_file_optional" | t }}</span><input class="block w-full text-sm text-gray-700" type="file" name="design_file" accept=".json,.txt"></label>
    <p class="mb-4 text-xs text-gray-500">{{ "events.views.label_form.upload_a" | t }} <code>label-design-*.json</code> {{ "events.views.label_form.design_export_description" | t }}</p>
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit" title="{{ "events.views.label_form.create_label" | t }}" aria-label="{{ "events.views.label_form.create_label" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.label_form.create_label" | t }}</span>
    </button>
  </form>
</div>
