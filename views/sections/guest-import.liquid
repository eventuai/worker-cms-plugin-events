<div class="flex items-center justify-between gap-4 mb-4"><div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ listHref }}">← {{ listName }}</a><h1 class="text-2xl font-bold text-gray-900">{{ "events.views.guest_import.import_guests" | t }}</h1><p class="mt-1 text-sm text-gray-500">{{ eventName }}</p></div></div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:40rem">
  {% if error != blank %}<p class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{{ error }}</p>{% endif %}
  <form method="post" action="{{ action }}" enctype="multipart/form-data" data-long-running-form>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">{{ "events.views.guest_import.csv_file" | t }}</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="file" type="file" accept=".csv,text/csv" required></label>
    <p class="mt-1 text-sm text-gray-500" style="margin-bottom:1rem">{{ "events.views.guest_import.supported_columns_name_last_name_email_phone_organization_job_title_plus" | t }}</p>
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit" title="{{ "events.views.guest_import.preview_import" | t }}" aria-label="{{ "events.views.guest_import.preview_import" | t }}" data-loading-label="{{ "events.views.guest_import.reading_csv" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
      <span class="hidden lg:inline">{{ "events.views.guest_import.preview_import" | t }}</span>
    </button>
  </form>
</div>
<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
