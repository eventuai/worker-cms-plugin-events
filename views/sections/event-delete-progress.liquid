<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900">{{ "events.views.event_delete_progress.deleting_event" | t }}</h1>
  <p class="mt-1 text-sm text-gray-500">{{ eventName }}</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:40rem">
  <p class="text-sm text-gray-700 mb-4">{{ summary }}</p>
  {% if auto %}
    <p class="text-sm text-gray-600 mb-4">{{ "events.views.event_delete_progress.this_event_is_large_so_deletion_runs_in_stages_it_will_continue_automati" | t }}</p>
  {% else %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ "events.views.event_delete_progress.this_pass_could_not_make_progress_automatically_press_continue_deletion_" | t }}</div>
  {% endif %}

  <form method="post" action="{{ action }}" id="import-continue-form" data-auto="{% if auto %}1{% else %}0{% endif %}" data-long-running-form>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-red-600 px-4 text-sm font-semibold text-white hover:bg-red-700 cursor-pointer" title="{{ "events.views.event_delete_progress.continue_deletion" | t }}" aria-label="{{ "events.views.event_delete_progress.continue_deletion" | t }}" data-loading-label="{{ "events.views.event_delete_progress.continuing_deletion" | t }}">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg>
        <span class="hidden lg:inline">{{ "events.views.event_delete_progress.continue_deletion" | t }}</span>
      </button>
      <a href="{{ backHref }}" data-stop-continue class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "events.views.event_delete_progress.stop_for_now" | t }}</a>
    </div>
  </form>
</div>

<script src="/admin/plugins/events/assets/long-running-submit.js" defer></script>
<script src="/admin/plugins/events/assets/import-continue.js" defer></script>
