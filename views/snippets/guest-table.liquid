<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[680px] text-left"{% if reorderAction %} data-reorder="{{ reorderAction | escape }}" data-reorder-key="updates" data-reorder-mode="weight" data-reorder-handle-only{% endif %}>
    <thead class="bg-gray-50 border-b border-gray-200"><tr>
      {% if reorderAction %}<th class="px-4 py-3 w-10"></th>{% endif %}
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name / Email</th>
      {% if showListColumn %}<th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">List</th>{% endif %}
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organisation</th>
      {% if hasEdm %}<th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email&nbsp;send</th>{% endif %}
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
      {% if hasCustomFields %}
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
          <form method="get" action="{{ listHref | escape }}">
            {% if q != blank %}<input type="hidden" name="q" value="{{ q | escape }}">{% endif %}
            {% if selectedStatus != blank %}<input type="hidden" name="status" value="{{ selectedStatus | escape }}">{% endif %}
            {% if selectedColor != blank %}<input type="hidden" name="color" value="{{ selectedColor | escape }}">{% endif %}
            <select id="custom-field-selector" class="border-0 bg-transparent p-0 text-xs font-semibold uppercase tracking-wider text-gray-500 cursor-pointer max-w-[12rem]" name="cf" data-autosubmit>
              <option value="">Custom field</option>
              {% for field in customFieldOptions %}
                <option value="{{ field.key | escape }}"{% if field.selected %} selected{% endif %}>{{ field.label | escape }}</option>
              {% endfor %}
            </select>
          </form>
        </th>
      {% endif %}
      <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Check-in</th>
      <th class="px-6 py-3"></th>
    </tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr{% if reorderAction %} data-id="{{ guest.id }}"{% endif %}>
          {% if reorderAction %}<td class="px-4 py-3 text-gray-400" data-reorder-handle title="Drag to reorder" style="cursor:grab"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" d="M9 5h.01M9 12h.01M9 19h.01M15 5h.01M15 12h.01M15 19h.01" /></svg></td>{% endif %}
          <td class="px-6 py-3 text-sm text-gray-700">
            <a class="block text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">{{ guest.name | escape }}</a>
            {% if guest.color_tag %}
              <div class="mt-1 inline-flex items-center gap-1 text-xs text-gray-500"><span class="inline-block h-2.5 w-2.5 rounded-full border border-gray-300" style="background-color:{{ guest.color_tag | escape }}"></span>{{ guest.color_tag | escape }}</div>
            {% endif %}
            <div class="text-gray-500 text-sm">
              {{ guest.email | escape }}
              {% if hasEdm and guest.hasEdm %}
                {% if guest.isGood %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700">good</span>
                {% elsif guest.isRisky %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-700">risky</span>
                {% else %}<span class="ml-1 inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">no email</span>{% endif %}
              {% endif %}
            </div>
          </td>
          {% if showListColumn %}<td class="px-6 py-3 text-sm text-gray-700">{{ guest.listName | escape }}</td>{% endif %}
          <td class="px-6 py-3 text-sm text-gray-700">
            {{ guest.organization | escape }}
            {% if guest.job_title %}
              <div class="text-gray-500 text-sm">{{ guest.job_title | escape }}</div>
            {% endif %}
          </td>
          {% if hasEdm %}
            <td class="px-6 py-3 text-sm text-gray-700">
              {% if guest.hasEdm %}
                {% if guest.canEmail %}
                  {% if guest.notSend %}
                    <span class="text-xs text-gray-400">Paused</span>
                  {% else %}
                    <span class="inline-flex items-center gap-2">
                      <form method="post" action="{{ guest.sendAction | escape }}" class="inline-block">
                        {% if guest.returnTo %}<input type="hidden" name="return_to" value="{{ guest.returnTo | escape }}">{% endif %}
                        {% if guest.sent %}
                          <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Re-send</button>
                        {% elsif guest.isGood %}
                          <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold bg-green-600 text-white hover:bg-green-700 cursor-pointer">Send</button>
                        {% else %}
                          <button type="submit" class="inline-block px-3 py-1.5 rounded-lg text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-300 hover:bg-gray-50 cursor-pointer">Send</button>
                        {% endif %}
                      </form>
                      <a class="text-xs font-semibold text-indigo-600 hover:text-indigo-800" href="{{ guest.previewHref | escape }}" target="_blank" rel="noopener">Preview</a>
                    </span>
                  {% endif %}
                {% else %}
                  <span class="text-xs text-gray-400">No email</span>
                {% endif %}
              {% else %}
                <span class="text-xs text-gray-400">No EDM</span>
              {% endif %}
            </td>
          {% endif %}
          <td class="px-6 py-3 text-sm text-gray-700">
            <form method="post" action="{{ guest.statusAction | escape }}">
              {% if guest.returnTo %}<input type="hidden" name="return_to" value="{{ guest.returnTo | escape }}">{% endif %}
              <select class="border border-gray-300 rounded-md p-1 text-xs bg-white max-w-[9rem] {{ guest.statusClass | escape }}" style="color:{{ guest.statusColor | escape }}" name="status" data-autosubmit>
                {% for status in statuses %}<option value="{{ status | escape }}"{% if status == guest.status %} selected{% endif %}>{{ status | escape }}</option>{% endfor %}
              </select>
            </form>
          </td>
          {% if hasCustomFields %}
            <td class="px-6 py-3 text-sm text-gray-700">
              {% if selectedCustomFieldKey != blank %}
                {% if guest.customFieldValue != blank %}
                  {{ guest.customFieldValue | escape }}
                {% else %}
                  <span class="text-gray-400 italic">—</span>
                {% endif %}
              {% else %}
                <span class="text-gray-400 italic">—</span>
              {% endif %}
            </td>
          {% endif %}
          <td class="px-6 py-3 text-sm text-gray-700">{% if guest.checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Checked in</span>{% else %}<form method="post" action="{{ guest.checkinAction | escape }}">{% if guest.returnTo %}<input type="hidden" name="return_to" value="{{ guest.returnTo | escape }}">{% endif %}<button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer" type="submit">Check in</button></form>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.qrHref | escape }}">QR</a> · <a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ guest.editHref | escape }}">Edit →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="99" class="px-6 py-10 text-center text-sm text-gray-400">{{ emptyMessage | default: "No guests match this list." }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
