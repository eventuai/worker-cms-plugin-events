{% if field.type == "checkbox" %}
  <label class="flex min-w-0 items-center gap-2 text-sm text-gray-700">
    <input id="{{ field.id | escape }}" class="h-4 w-4 rounded border-gray-300" type="checkbox"
           name="{{ field.inputName | escape }}"
           value="{{ field.defaultValue | default: 'yes' | escape }}"
           {% if field.checked %}checked{% endif %}
           {% if field.required %}required{% endif %}>
    <span>{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
  </label>
{% elsif field.type == "select" %}
  <label for="{{ field.id | escape }}" class="min-w-0 block">
    <span class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
    <select id="{{ field.id | escape }}" name="{{ field.inputName | escape }}"
            class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
            {% if field.required %}required{% endif %}>
      {% if field.blankOption %}<option value=""{% if field.value == "" or field.value == nil %} selected{% endif %}>{{ field.blankLabel | escape }}</option>{% endif %}{% for option in field.options %}
      <option value="{{ option.value | escape }}"{% if option.selected %} selected{% endif %}>{{ option.label | escape }}</option>{% endfor %}
    </select>
  </label>
{% elsif field.type == "radio" %}
  <fieldset class="min-w-0 block">
    <legend class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</legend>
    <div class="flex flex-wrap gap-3">
      {% for option in field.options %}
        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="radio" name="{{ field.inputName | escape }}" value="{{ option.value | escape }}"{% if option.selected %} checked{% endif %}{% if field.required %} required{% endif %}>
          <span>{{ option.label | escape }}</span>
        </label>
      {% endfor %}
    </div>
  </fieldset>
{% elsif field.type == "textarea" or field.type == "richtext/md" %}
  <label for="{{ field.id | escape }}" class="min-w-0 block">
    <span class="flex items-center justify-between gap-2 mb-1">
      <span class="block text-sm font-medium text-gray-700">{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
      {% if field.type == "richtext/md" %}<span class="text-xs text-gray-400">Markdown / HTML</span>{% endif %}
    </span>
    <textarea id="{{ field.id | escape }}" name="{{ field.inputName | escape }}" rows="{% if field.type == 'richtext/md' %}10{% else %}4{% endif %}"
              placeholder="{{ field.placeholder | escape }}"
              class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if field.type == 'richtext/md' %} font-mono leading-relaxed{% endif %} focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-y"
              {% if field.required %}required{% endif %}>{{ field.value | escape }}</textarea>
  </label>
{% else %}
  <label for="{{ field.id | escape }}" class="min-w-0 block">
    <span class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
    <input id="{{ field.id | escape }}" type="{{ field.type | default: 'text' | escape }}" name="{{ field.inputName | escape }}"
           value="{{ field.value | escape }}"
           placeholder="{{ field.placeholder | escape }}"
           class="{% if field.type == 'color' %}block h-10 min-w-0 w-full max-w-full rounded-lg border border-gray-300{% else %}block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent{% endif %}"
           {% if field.required %}required{% endif %}>
  </label>
{% endif %}
